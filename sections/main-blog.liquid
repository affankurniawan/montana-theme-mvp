<section class="main-blog">
  {%- render 'section-heading', eyebrow: 'Blog', title: blog.title, text: 'Use practical and searchable content to make Montana useful, not just transactional.' -%}
  <div class="grid grid--3">
    {%- for article in blog.articles -%}
      {%- render 'article-card', article: article -%}
    {%- else -%}
      {%- render 'article-card', placeholder_title: "Belum ada artikel", placeholder_tag: "INFO", placeholder_date: "Hari ini", placeholder_read: "2 menit", placeholder_excerpt: "Nantikan artikel tips dan trik menarik serta panduan sekolah dari Montana." -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Main blog",
  "settings": []
}
{% endschema %}
