<section class="section section--spacious">
  <div class="page-width">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px;">
      
      <!-- Card 1 -->
      <div class="card" style="padding: 32px; background: #111; border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; display: flex; flex-direction: column; gap: 24px;">
        <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="#ffd800" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
        <div>
          <h3 style="margin: 0 0 12px; font-family: var(--font-heading); color: #fff; font-size: 1.2rem; text-transform: uppercase; font-weight: 800;">DUKUNGAN TEKNIS</h3>
          <p style="margin: 0; color: #aaa; font-size: 0.95rem; line-height: 1.6;">Butuh bantuan instalasi atau pemilihan komponen stationery? Tim teknis kami siap membantu.</p>
        </div>
        <a href="#ContactFormName" style="margin-top: auto; display: inline-flex; align-items: center; gap: 8px; color: #ff0000; text-decoration: none; font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; transition: color 0.2s;" onmouseover="this.style.color='#cc0000'" onmouseout="this.style.color='#ff0000'">
          HUBUNGI KONSULTAN <span aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <!-- Card 2 -->
      <div class="card" style="padding: 32px; background: #111; border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; display: flex; flex-direction: column; gap: 24px;">
        <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="#ffd800" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
        <div>
          <h3 style="margin: 0 0 12px; font-family: var(--font-heading); color: #fff; font-size: 1.2rem; text-transform: uppercase; font-weight: 800;">LAYANAN PENJUALAN</h3>
          <p style="margin: 0; color: #aaa; font-size: 0.95rem; line-height: 1.6;">Informasi ketersediaan stok, harga grosir, dan penawaran khusus untuk kebutuhan skala besar.</p>
        </div>
        <a href="/pages/katalog" style="margin-top: auto; display: inline-flex; align-items: center; gap: 8px; color: #ff0000; text-decoration: none; font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; transition: color 0.2s;" onmouseover="this.style.color='#cc0000'" onmouseout="this.style.color='#ff0000'">
          CEK KATALOG <span aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <!-- Card 3 -->
      <div class="card" style="padding: 32px; background: #111; border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; display: flex; flex-direction: column; gap: 24px;">
        <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="#ffd800" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
        <div>
          <h3 style="margin: 0 0 12px; font-family: var(--font-heading); color: #fff; font-size: 1.2rem; text-transform: uppercase; font-weight: 800;">PUSAT BANTUAN</h3>
          <p style="margin: 0; color: #aaa; font-size: 0.95rem; line-height: 1.6;">Pertanyaan umum seputar garansi, pengiriman, dan kebijakan pengembalian barang.</p>
        </div>
        <a href="#shopify-section-faq" style="margin-top: auto; display: inline-flex; align-items: center; gap: 8px; color: #ff0000; text-decoration: none; font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; transition: color 0.2s;" onmouseover="this.style.color='#cc0000'" onmouseout="this.style.color='#ff0000'">
          BACA FAQ <span aria-hidden="true">&rarr;</span>
        </a>
      </div>

    </div>
  </div>
</section>

