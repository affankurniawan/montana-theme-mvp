<section class="section section--spacious{% if section.settings.surface %} surface{% endif %}">
  <div class="page-width">
    <div class="richtext" style="text-align: center; margin: 0 auto;">
      {%- render 'section-heading', eyebrow: section.settings.eyebrow, title: section.settings.heading, text: section.settings.text, alignment: 'center' -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="button {% if section.settings.use_accent %}button--accent{% endif %}">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich text CTA",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Purpose strip"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Smart value today. Bigger impact tomorrow."},
    {"type": "textarea", "id": "text", "label": "Text", "default": "Use this section to explain the founder belief without overpowering the product story."},
    {"type": "checkbox", "id": "surface", "label": "Use surface background", "default": true},
    {"type": "checkbox", "id": "use_accent", "label": "Use accent button", "default": true},
    {"type": "text", "id": "button_label", "label": "Button label", "default": "Explore products"},
    {"type": "url", "id": "button_link", "label": "Button link"}
  ],
  "presets": [{"name": "Rich text CTA"}]
}
{% endschema %}
