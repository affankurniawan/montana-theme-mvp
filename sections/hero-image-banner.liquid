<section class="hero-banner-image" style="position:relative; width:100%; min-height:600px; aspect-ratio: 21/9; padding: 40px 24px; box-sizing: border-box; display:flex; align-items:flex-end; justify-content:center; overflow:hidden; background: #000;">
  <style>
    .hero-desktop-img { display: block; }
    .hero-mobile-img { display: none; }
    @media screen and (max-width: 767px) {
      .hero-desktop-img { display: none; }
      .hero-mobile-img { display: block; }
    }
  </style>

  <!-- Desktop Image -->
  {%- if section.settings.image != blank -%}
    <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.image.alt | default: 'Montana Essentials Desktop' }}" class="hero-desktop-img" loading="eager" fetchpriority="high" style="position:absolute; top:0; left:0; width:100%; height:100%; object-fit: cover; object-position: center; z-index: 1;">
  {%- else -%}
    <img src="{{ 'hero.jpg' | asset_url }}" alt="Montana Essentials" class="hero-desktop-img" loading="eager" fetchpriority="high" style="position:absolute; top:0; left:0; width:100%; height:100%; object-fit: cover; object-position: center; z-index: 1;">
  {%- endif -%}

  <!-- Mobile Image -->
  {%- if section.settings.image_mobile != blank -%}
    <img src="{{ section.settings.image_mobile | img_url: 'master' }}" alt="{{ section.settings.image_mobile.alt | default: 'Montana Essentials Mobile' }}" class="hero-mobile-img" loading="eager" fetchpriority="high" style="position:absolute; top:0; left:0; width:100%; height:100%; object-fit: cover; object-position: center; z-index: 1;">
  {%- else -%}
    <img src="{{ 'hero.jpg' | asset_url }}" alt="Montana Essentials Mobile" class="hero-mobile-img" loading="eager" fetchpriority="high" style="position:absolute; top:0; left:0; width:100%; height:100%; object-fit: cover; object-position: center; z-index: 1;">
  {%- endif -%}
  
  <!-- Subtle Gradient Overlay to ensure buttons are readable at the bottom -->
  <div style="position:absolute; bottom:0; left:0; width:100%; height:40%; background:linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 100%); z-index:2; pointer-events:none;"></div>

  <!-- Content Layer (Buttons Only) -->
  <div class="page-width" style="position:absolute; top:58%; left:50%; transform: translateX(-50%); z-index:3; text-align:center; width:100%;">
      
      <!-- Pill Buttons (Double Stack) -->
      <div class="gsap-hero-buttons" style="display:flex; justify-content:center; gap:12px; flex-wrap:wrap;">
        {%- if section.settings.primary_label != blank -%}
          <a href="/pages/katalog" class="button button--accent" style="display:inline-flex; align-items:center; justify-content:center; font-size:0.85rem; padding: 10px 24px; font-weight:800; border-radius: 999px; background: var(--color-accent); color: #000; text-decoration: none; border: 2px solid var(--color-accent); box-shadow: 0 4px 14px rgba(255, 216, 0, 0.25); transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(255, 216, 0, 0.4)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 14px rgba(255, 216, 0, 0.25)'">{{ section.settings.primary_label }}</a>
        {%- endif -%}
        {%- if section.settings.secondary_label != blank -%}
          <a href="{{ section.settings.secondary_link }}" class="button button--secondary" style="display:inline-flex; align-items:center; justify-content:center; font-size:0.85rem; padding: 10px 24px; font-weight:800; border-radius: 999px; background: transparent; color: #000; text-decoration: none; border: 2px solid #000; transition: all 0.2s ease;" onmouseover="this.style.transform='translateY(-2px)'; this.style.background='#000'; this.style.color='var(--color-accent)'; this.style.boxShadow='0 6px 20px rgba(0, 0, 0, 0.3)';" onmouseout="this.style.transform='translateY(0)'; this.style.background='transparent'; this.style.color='#000'; this.style.boxShadow='none';">{{ section.settings.secondary_label }}</a>
        {%- endif -%}
      </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    gsap.registerPlugin(ScrollTrigger);

    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });
    tl.fromTo(".gsap-hero-buttons", { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 1, delay: 0.2 });
  });
</script>

{% schema %}
{
  "name": "Hero Image Banner",
  "settings": [
    {"type": "image_picker", "id": "image", "label": "Background Image (Desktop)"},
    {"type": "image_picker", "id": "image_mobile", "label": "Background Image (Mobile 9:16)"},
    {"type": "text", "id": "primary_label", "label": "Primary button label", "default": "Belanja Produk"},
    {"type": "url", "id": "primary_link", "label": "Primary button link"},
    {"type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Tentang Montana"},
    {"type": "url", "id": "secondary_link", "label": "Secondary button link"}
  ],
  "presets": [{"name": "Hero Image Banner"}]
}
{% endschema %}
