<section class="hero-banner-image {% if section.settings.enable_bottom_align %}hero-banner-bottom{% else %}hero-banner-center{% endif %}" style="position:relative; width:100%; min-height:600px; padding: 40px 24px; box-sizing: border-box; display:flex; justify-content:center; overflow:hidden; background: #000;">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;800&display=swap');
    
    .hero-banner-center { align-items: center; aspect-ratio: 21/9; }
    .hero-banner-bottom { align-items: flex-end; aspect-ratio: inherit; }
    .hero-desktop-img { display: block; }
    .hero-mobile-img { display: none; }
    
    .gsap-hero-heading {
      font-family: 'Montserrat', sans-serif;
      font-weight: 800;
      font-size: 64px;
      line-height: 1.1;
      margin: 0 0 16px 0;
    }
    
    .gsap-hero-subtext {
      font-family: 'Montserrat', sans-serif;
      font-weight: 500;
      font-size: 21px;
      line-height: 1.5;
      max-width: 650px;
      margin: 0 auto 32px auto;
    }

    @media screen and (max-width: 767px) {
      .hero-desktop-img { display: none; }
      .hero-mobile-img { display: block; }
      .hero-banner-center, .hero-banner-bottom { 
        min-height: 90vh; 
        aspect-ratio: inherit; 
        align-items: flex-start; 
        padding-top: 11vh; 
      }
      
      .gsap-hero-heading {
        font-size: 32px;
        line-height: 1.15;
      }
      .gsap-hero-subtext {
        font-size: 11.5px;
        max-width: 280px;
        margin-left: auto;
        margin-right: auto;
        text-wrap: balance;
      }
      .gsap-hero-text {
        margin-bottom: 0 !important;
      }
    }
  </style>

  <!-- Desktop Image -->
  {%- if section.settings.image != blank -%}
    <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.image.alt | default: section.settings.heading | strip_html | escape }}" class="hero-desktop-img" loading="eager" fetchpriority="high" style="position:absolute; top:0; left:0; width:100%; height:100%; object-fit: cover; object-position: center; z-index: 1;">
  {%- else -%}
    <img src="{{ 'hero.jpg' | asset_url }}" alt="Montana Essentials" class="hero-desktop-img" loading="eager" fetchpriority="high" style="position:absolute; top:0; left:0; width:100%; height:100%; object-fit: cover; object-position: center; z-index: 1;">
  {%- endif -%}

  <!-- Mobile Image -->
  {%- if section.settings.image_mobile != blank -%}
    <img src="{{ section.settings.image_mobile | img_url: 'master' }}" alt="{{ section.settings.image_mobile.alt | default: section.settings.heading | strip_html | escape }}" class="hero-mobile-img" loading="eager" fetchpriority="high" style="position:absolute; top:0; left:0; width:100%; height:100%; object-fit: cover; object-position: center; z-index: 1;">
  {%- else -%}
    <img src="{{ 'hero.jpg' | asset_url }}" alt="Montana Essentials Mobile" class="hero-mobile-img" loading="eager" fetchpriority="high" style="position:absolute; top:0; left:0; width:100%; height:100%; object-fit: cover; object-position: center; z-index: 1;">
  {%- endif -%}
  
  <!-- Overlay -->
  {%- assign overlay_opacity = section.settings.overlay_opacity | times: 1.0 | divided_by: 100.0 -%}
  <div style="position:absolute; inset:0; background: {{ section.settings.overlay_color }}; opacity: {{ overlay_opacity }}; z-index:2; pointer-events:none;"></div>

  <!-- Content Layer -->
  <div class="page-width" style="position:relative; z-index:3; text-align:center; width:100%; color: {{ section.settings.text_color }};">
      
      <div class="gsap-hero-text" style="max-width: 800px; margin: 0 auto 60px auto; display:flex; flex-direction:column; align-items:center;">
        {%- if section.settings.eyebrow != blank -%}
          <div style="font-size: clamp(0.75rem, 2vw, 0.875rem); font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color: var(--color-accent); margin-bottom:16px;">
            {{ section.settings.eyebrow }}
          </div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class="gsap-hero-heading" style="color: {{ section.settings.text_color }};">
            {{ section.settings.heading | newline_to_br }}
          </h1>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="gsap-hero-subtext" style="opacity: 0.9;">
            {{ section.settings.text | newline_to_br }}
          </div>
        {%- endif -%}

        <!-- Pill Buttons -->
        <div class="gsap-hero-buttons" style="display:flex; justify-content:center; gap:12px; flex-wrap:wrap; margin-top: 10px;">
          {%- if section.settings.primary_label != blank -%}
            <a href="{{ section.settings.primary_link }}" class="button button--accent" style="display:inline-flex; align-items:center; justify-content:center; font-size:0.85rem; padding: 12px 28px; font-weight:800; border-radius: 999px; background: var(--color-accent); color: #000; text-decoration: none; border: 2px solid var(--color-accent); box-shadow: 0 4px 14px rgba(255, 216, 0, 0.25); transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(255, 216, 0, 0.4)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 14px rgba(255, 216, 0, 0.25)'">
              {{ section.settings.primary_label }}
            </a>
          {%- endif -%}
          {%- if section.settings.secondary_label != blank -%}
            <a href="{{ section.settings.secondary_link }}" class="button button--secondary" style="display:inline-flex; align-items:center; justify-content:center; font-size:0.85rem; padding: 12px 28px; font-weight:800; border-radius: 999px; background: transparent; color: {{ section.settings.text_color }}; text-decoration: none; border: 2px solid {{ section.settings.text_color }}; transition: all 0.2s ease;" onmouseover="this.style.transform='translateY(-2px)'; this.style.background='{{ section.settings.text_color }}'; this.style.color='#000'; this.style.boxShadow='0 6px 20px rgba(0, 0, 0, 0.15)';" onmouseout="this.style.transform='translateY(0)'; this.style.background='transparent'; this.style.color='{{ section.settings.text_color }}'; this.style.boxShadow='none';">
              {{ section.settings.secondary_label }}
            </a>
          {%- endif -%}
        </div>
      </div>

  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    gsap.registerPlugin(ScrollTrigger);

    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });
    tl.fromTo(".gsap-hero-text > *", 
      { opacity: 0, y: 30 }, 
      { opacity: 1, y: 0, duration: 1, stagger: 0.15, delay: 0.2 }
    );
  });
</script>

{% schema %}
{
  "name": "Hero Image Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Background Image (Mobile 9:16)"
    },
    {
      "type": "header",
      "content": "Typography Layer"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "Be Smart With Montana"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Subtext"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & Outline Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Overlay & Styling"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Filter Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay Filter Opacity",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "enable_bottom_align",
      "label": "Align content to bottom",
      "default": false
    },
    {
      "type": "header",
      "content": "Call To Action"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Belanja Produk"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Tentang Montana"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Hero Image Banner"
    }
  ]
}
{% endschema %}
