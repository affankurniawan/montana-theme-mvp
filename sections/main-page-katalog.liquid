<section class="main-collection page-width" style="padding: 40px 0 80px;">
  
  <!-- Breadcrumbs -->
  <div class="breadcrumbs" style="color: rgba(18,19,21,0.6); font-size: 0.85rem; margin-bottom: 24px; font-weight: 500; display:flex; align-items:center; gap: 8px;">
    <a href="/" style="color: #121315; text-decoration: none;">Beranda</a> 
    <span>/</span> 
    <span style="color: #333;">{{ page.title }}</span>
  </div>

  <div style="display: flex; gap: 32px; align-items: flex-start;" class="catalog-layout">
    
    <!-- Sidebar -->
    <aside class="catalog-sidebar" style="width: 250px; flex-shrink: 0; display: flex; flex-direction: column; gap: 24px; position: sticky; top: 100px; max-height: calc(100vh - 120px);">
      
      <form action="{{ routes.search_url }}" method="get" role="search" style="display: flex; background: #fff; border: 1px solid rgba(18,19,21,0.1); border-radius: 8px; overflow: hidden; height: 44px; flex-shrink: 0; transition: border-color 0.2s;" onfocusin="this.style.borderColor='rgba(18,19,21,0.5)'" onfocusout="this.style.borderColor='rgba(18,19,21,0.1)'">
        <input type="hidden" name="type" value="product">
        <div style="display: flex; align-items: center; justify-content: center; padding-left: 12px; color: #121315;">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </div>
        <input type="search" name="q" placeholder="Cari produk..." style="flex-grow: 1; padding: 0 12px; border: none; background: transparent; color: #121315; font-size: 0.9rem; outline: none;">
      </form>

      <div style="overflow-y: auto; flex-grow: 1; padding-right: 8px;" class="custom-scrollbar catalog-categories-wrapper">
        <!-- Desktop Category Menu (Persistent) -->
        <div class="sidebar-categories-desktop">
          <h4 style="font-size: 0.85rem; color: #121315; font-weight: 700; letter-spacing: 1px; margin: 0 0 16px; display: flex; align-items: center; gap: 8px; text-transform: uppercase;">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" style="opacity:0.8;"><line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="18" x2="20" y2="18"></line></svg>
            Kategori
          </h4>
          <nav style="display: flex; flex-direction: column; gap: 4px;">
            <a href="/pages/katalog" style="padding: 10px 12px; background: #121315; color: var(--color-accent); font-weight: 600; text-decoration: none; font-size: 0.9rem; border-radius: 6px;">Semua</a>
            {%- for type in collections.all.all_types -%}
              {%- if type != blank -%}
                <a href="{{ routes.search_url }}?type=product&q={{ type | url_encode }}" style="padding: 10px 12px; background: transparent; color: rgba(18,19,21,0.6); font-weight: 600; text-decoration: none; font-size: 0.9rem; border-radius: 6px; transition: all 0.2s;" onmouseover="this.style.background='#121315'; this.style.color='#00B2FF'" onmouseout="this.style.background='transparent'; this.style.color='rgba(18,19,21,0.6)'">{{ type }}</a>
              {%- endif -%}
            {%- endfor -%}
          </nav>
        </div>

        <!-- Mobile Category Menu (Dropdown / Accordion) -->
        <details class="sidebar-categories-mobile">
          <summary style="font-size: 0.9rem; color: #121315; font-weight: 700; padding: 12px 16px; background: #fff; border: 2px solid #121315; border-radius: 8px; display: flex; align-items: center; justify-content: space-between; cursor: pointer; text-transform: uppercase; list-style: none;">
            <div style="display:flex; align-items:center; gap:8px;">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" style="opacity:0.8;"><line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="18" x2="20" y2="18"></line></svg>
              Saring Kategori  
            </div>
            <svg class="chevron-ico" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" style="transition: transform 0.3s;"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </summary>
          <div style="padding-top: 16px;">
            <nav style="display: flex; flex-direction: row; flex-wrap: wrap; gap: 8px;">
              <a href="/pages/katalog" style="padding: 8px 16px; background: #121315; color: var(--color-accent); font-weight: 600; text-decoration: none; font-size: 0.85rem; border-radius: 6px; border: 1px solid #121315;">Semua</a>
              {%- for type in collections.all.all_types -%}
                {%- if type != blank -%}
                  <a href="{{ routes.search_url }}?type=product&q={{ type | url_encode }}" style="padding: 8px 16px; background: transparent; color: #121315; font-weight: 500; text-decoration: none; font-size: 0.85rem; border-radius: 6px; border: 1px solid rgba(18,19,21,0.2); transition: all 0.2s;" onmouseover="this.style.background='#121315'; this.style.color='#00B2FF'" onmouseout="this.style.background='transparent'; this.style.color='#121315'">{{ type }}</a>
                {%- endif -%}
              {%- endfor -%}
            </nav>
          </div>
        </details>
      </div>

    </aside>

    <!-- Main Content -->
    <div style="flex-grow: 1;">
      
      <header style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; flex-wrap: wrap; gap: 16px;">
        <div>
          <h1 style="font-family: var(--font-heading); font-size: 2.2rem; font-weight: 800; margin: 0 0 4px; text-transform:none; color: #121315;">Katalog Produk</h1>
          <span style="color: rgba(18,19,21,0.6); font-weight: 500; font-size: 0.95rem;">{{ collections.all.all_products_count }} produk ditemukan</span>
        </div>
        
        <div style="position: relative;">
           <select name="sort_by" id="CatalogSortBy" style="appearance: none; background: #121315; color: #00B2FF; border: 2px solid #121315; padding: 10px 40px 10px 16px; border-radius: 8px; font-size: 0.9rem; font-weight: 700; cursor: pointer; outline: none; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 4px 10px rgba(0,0,0,0.15);" onmouseover="this.style.boxShadow='0 6px 15px rgba(0,0,0,0.25)'; this.style.transform='translateY(-2px)';" onmouseout="this.style.boxShadow='0 4px 10px rgba(0,0,0,0.15)'; this.style.transform='translateY(0)';">
             <option value="" disabled selected style="background: #121315; color: #aaa;">Pilih Urutan</option>
             <option value="price-ascending" style="background: #121315; color: #fff;">Harga Terendah</option>
             <option value="price-descending" style="background: #121315; color: #fff;">Harga Tertinggi</option>
           </select>
           <script>
             document.addEventListener('DOMContentLoaded', function() {
               const urlParams = new URLSearchParams(window.location.search);
               const currentSort = urlParams.get('sort_by');
               const sortSelect = document.getElementById('CatalogSortBy');
               
               if (currentSort) {
                 sortSelect.value = currentSort;
               }

               sortSelect.addEventListener('change', function() {
                 let params = new URLSearchParams(window.location.search);
                 params.set('sort_by', this.value);
                 window.history.replaceState(null, null, '?' + params.toString());
                 
                 const grid = document.querySelector('.product-grid');
                 const cards = Array.from(grid.querySelectorAll('.product-card'));
                 
                 cards.sort((a, b) => {
                   const priceA = parseInt(a.getAttribute('data-price')) || 0;
                   const priceB = parseInt(b.getAttribute('data-price')) || 0;
                   
                   if (this.value === 'price-ascending') {
                     return priceA - priceB;
                   } else if (this.value === 'price-descending') {
                     return priceB - priceA;
                   }
                   return 0;
                 });
                 
                 const pagination = grid.querySelector('.pagination');
                 cards.forEach(card => {
                   if (pagination) {
                     grid.insertBefore(card, pagination);
                   } else {
                     grid.appendChild(card);
                   }
                 });
               });
               
               if (currentSort === 'price-ascending' || currentSort === 'price-descending') {
                 sortSelect.dispatchEvent(new Event('change'));
               }
             });
           </script>
           <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#00B2FF" stroke-width="2.5" style="position: absolute; right: 14px; top: 12px; pointer-events: none;"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </div>
      </header>

      <div class="product-grid" style="row-gap: 32px; column-gap: 16px;">
        {%- paginate collections.all.products by 48 -%}
          {%- for product in collections.all.products -%}
            {%- render 'product-card', product: product -%}
          {%- else -%}
            <div class="proof-card" style="grid-column: 1 / -1; text-align: center;">
              <h3>Katalog Sedang Kosong</h3>
              <p>Sistem tidak dapat mendeteksi produk di kanal Online Store Anda. Harap pastikan 200 produk Anda dicentang (Included) ke Online Store Sales Channels.</p>
            </div>
          {%- endfor -%}

          {%- if paginate.pages > 1 -%}
            <style>
              .pagination { font-size: 1.1rem; font-weight: 600; }
              .pagination a, .pagination span.page, .pagination span.next, .pagination span.prev {
                display: inline-flex; align-items: center; justify-content: center;
                min-width: 44px; height: 44px; padding: 0 12px;
                text-decoration: none; color: #121315; border-radius: 8px; transition: all 0.2s;
              }
              .pagination a:hover { background: rgba(18,19,21,0.1); }
              .pagination span.current {
                background: #121315; color: var(--color-accent); font-weight: 800;
              }
              .pagination span.deco { min-width: 24px; color: rgba(18,19,21,0.5); display: inline-flex; align-items: center; justify-content: center; }
            </style>
            <div class="pagination" style="grid-column: 1 / -1; display:flex; justify-content:center; gap:8px; margin-top:48px; margin-bottom: 32px; flex-wrap:wrap;">
              {{ paginate | default_pagination }}
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>

    </div>

  </div>
  
  <style>
    .sidebar-categories-mobile { display: none; }
    .sidebar-categories-desktop { display: block; }
    
    @media (max-width: 900px) {
      .catalog-layout { flex-direction: column; gap: 24px; }
      .catalog-sidebar { width: 100% !important; position: static !important; }
      
      .sidebar-categories-desktop { display: none; }
      .sidebar-categories-mobile { display: block; }
      details.sidebar-categories-mobile[open] summary .chevron-ico { transform: rotate(180deg); }
      details.sidebar-categories-mobile summary::-webkit-details-marker { display: none; }
    }
  </style>
</section>

{% schema %}
{
  "name": "Katalog Page Grid",
  "settings": []
}
{% endschema %}
