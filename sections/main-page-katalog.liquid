<section class="main-collection">
  <div style="text-align: center; margin-bottom: 40px; display: flex; flex-direction: column; align-items: center;">
    <div class="breadcrumbs" style="color: #aaa; font-size: 0.9rem; margin-bottom: 12px; font-weight: 500;"><a href="/" style="color: #fff; text-decoration: none;">Home</a> <span style="margin: 0 4px;">/</span> <span style="color: var(--color-accent);">{{ page.title }}</span></div>
    {%- assign catalog_text = 'Browse our entire selection of ' | append: collections.all.all_products_count | append: ' durable essentials at smart prices.' -%}
    {%- render 'section-heading', eyebrow: 'Product hub', title: page.title, text: catalog_text, alignment: 'center' -%}
  </div>

  <div class="katalog-tools" style="max-width: 680px; margin: 0 auto 48px auto; padding: 0 20px;">
    <form action="{{ routes.search_url }}" method="get" role="search" style="display: flex; gap: 8px; margin-bottom: 24px;">
      <input type="hidden" name="type" value="product">
      <input type="search" name="q" placeholder="Search pens, calculators, paper..." style="flex-grow: 1; padding: 14px 24px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.15); background: rgba(0,0,0,0.4); color: #fff; font-size: 1rem; outline: none; box-shadow: inset 0 2px 4px rgba(0,0,0,0.5);">
      <button type="submit" class="button button--accent" style="border-radius: 999px; padding: 14px 28px; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </button>
    </form>
    
    <div class="katalog-categories" style="display: flex; flex-wrap: wrap; gap: 8px; justify-content: center;">
      <a href="/pages/katalog" style="padding: 8px 18px; border-radius: 999px; background: var(--color-accent); color: #000; font-weight: 700; text-decoration: none; font-size: 0.9rem; box-shadow: 0 4px 12px rgba(255, 216, 0, 0.2);">All Products</a>
      <a href="{{ routes.search_url }}?type=product&q=pulpen+OR+tinta+OR+ballpoint+OR+pen+OR+pena+OR+gel" style="padding: 8px 18px; border-radius: 999px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; font-weight: 500; text-decoration: none; font-size: 0.9rem;">Pens</a>
      <a href="{{ routes.search_url }}?type=product&q=pensil+OR+raut+OR+penghapus+OR+serutan+OR+pencil+OR+eraser" style="padding: 8px 18px; border-radius: 999px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; font-weight: 500; text-decoration: none; font-size: 0.9rem;">Pencils / Sharpeners</a>
      <a href="{{ routes.search_url }}?type=product&q=kalkulator+OR+calculator" style="padding: 8px 18px; border-radius: 999px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; font-weight: 500; text-decoration: none; font-size: 0.9rem;">Calculators</a>
      <a href="{{ routes.search_url }}?type=product&q=kertas+OR+buku+OR+notes+OR+book+OR+paper+OR+memo" style="padding: 8px 18px; border-radius: 999px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; font-weight: 500; text-decoration: none; font-size: 0.9rem;">Books / Paper</a>
      <a href="{{ routes.search_url }}?type=product&q=label+OR+stiker+OR+sticker+OR+nama+OR+tag" style="padding: 8px 18px; border-radius: 999px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; font-weight: 500; text-decoration: none; font-size: 0.9rem;">Stickers / Labels</a>
      <a href="{{ routes.search_url }}?type=product&q=korek+OR+api+OR+gas+OR+m2000+OR+lighter+OR+pemantik" style="padding: 8px 18px; border-radius: 999px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; font-weight: 500; text-decoration: none; font-size: 0.9rem;">Lighters</a>
      <a href="{{ routes.search_url }}?type=product&q=gunting+OR+cutter+OR+lem+OR+rak+OR+binder+OR+office+OR+kantor+OR+isolasi+OR+lakban+OR+tape" style="padding: 8px 18px; border-radius: 999px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; font-weight: 500; text-decoration: none; font-size: 0.9rem;">Office Supplies</a>
      <a href="{{ routes.search_url }}?type=product&q=penggaris+OR+jangka+OR+tipe-x+OR+correction+OR+spidol+OR+marker+OR+pianika+OR+tiup+OR+musik+OR+seruling" style="padding: 8px 18px; border-radius: 999px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; font-weight: 500; text-decoration: none; font-size: 0.9rem;">School Supplies</a>
    </div>
  </div>

  <div class="product-grid">
    {%- paginate collections.all.products by 48 -%}
      {%- if paginate.pages > 1 -%}
        <style>
          .pagination { font-size: 1.1rem; font-weight: 500; }
          .pagination a, .pagination span.page, .pagination span.next, .pagination span.prev {
            display: inline-flex; align-items: center; justify-content: center;
            min-width: 44px; height: 44px; padding: 0 12px;
            text-decoration: none; color: #fff; border-radius: 8px; transition: all 0.2s;
          }
          .pagination a:hover { background: rgba(255,255,255,0.1); }
          .pagination span.current {
            background: var(--color-accent); color: #000; font-weight: 700;
            box-shadow: 0 4px 12px rgba(255, 216, 0, 0.3);
          }
          .pagination span.deco { min-width: 24px; color: #888; display: inline-flex; align-items: center; justify-content: center; }
        </style>
        <div class="pagination" style="grid-column: 1 / -1; display:flex; justify-content:center; gap:8px; margin-bottom: 32px; flex-wrap:wrap;">
          {{ paginate | default_pagination }}
        </div>
      {%- endif -%}

      {%- for product in collections.all.products -%}
        {%- render 'product-card', product: product -%}
      {%- else -%}
        <div class="proof-card" style="grid-column: 1 / -1; text-align: center;">
          <h3>Katalog Sedang Kosong</h3>
          <p>Sistem tidak dapat mendeteksi produk di kanal Online Store Anda. Harap pastikan 200 produk Anda dicentang (Included) ke Online Store Sales Channels.</p>
        </div>
      {%- endfor -%}

      {%- if paginate.pages > 1 -%}
        <div class="pagination" style="grid-column: 1 / -1; display:flex; justify-content:center; gap:8px; margin-top:48px; margin-bottom: 32px; flex-wrap:wrap;">
          {{ paginate | default_pagination }}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Katalog Page Grid",
  "settings": []
}
{% endschema %}
