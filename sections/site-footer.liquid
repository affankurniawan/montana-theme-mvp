<footer class="footer">
  <div class="page-width footer__inner" style="display:block;">
    <div class="footer__grid" style="gap:48px;">
      <div>
        <a href="{{ routes.root_url }}" style="display:inline-block; margin-bottom: 20px;">
          <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" style="max-height: 48px; width: auto;" loading="lazy">
        </a>
        <h3 style="margin-top:0; color: var(--color-primary);">{{ section.settings.footer_heading }}</h3>
        <p style="color: rgba(255,255,255,0.7);">{{ section.settings.footer_text }}</p>
        <div style="margin-top: 24px; display: flex; gap: 16px; align-items: center;">
          <a href="{{ settings.social_instagram_link | default: '#' }}" target="_blank" rel="noopener" aria-label="Instagram" style="display:inline-flex; align-items:center; justify-content:center; width: 44px; height: 44px; border-radius: 50%; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); color: #fff; transition: all 0.3s ease;" onmouseover="this.style.background='var(--color-accent)'; this.style.color='#000'; this.style.transform='translateY(-6px)';" onmouseout="this.style.background='rgba(255,255,255,0.05)'; this.style.color='#fff'; this.style.transform='translateY(0)';">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
          <a href="{{ settings.social_tiktok_link | default: '#' }}" target="_blank" rel="noopener" aria-label="TikTok" style="display:inline-flex; align-items:center; justify-content:center; width: 44px; height: 44px; border-radius: 50%; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); color: #fff; transition: all 0.3s ease;" onmouseover="this.style.background='var(--color-accent)'; this.style.color='#000'; this.style.transform='translateY(-6px)';" onmouseout="this.style.background='rgba(255,255,255,0.05)'; this.style.color='#fff'; this.style.transform='translateY(0)';">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
          </a>
          <a href="https://wa.me/{{ settings.whatsapp_number }}" target="_blank" rel="noopener" aria-label="WhatsApp" style="display:inline-flex; align-items:center; justify-content:center; width: 44px; height: 44px; border-radius: 50%; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); color: #fff; transition: all 0.3s ease;" onmouseover="this.style.background='var(--color-accent)'; this.style.color='#000'; this.style.transform='translateY(-6px)';" onmouseout="this.style.background='rgba(255,255,255,0.05)'; this.style.color='#fff'; this.style.transform='translateY(0)';">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
          </a>
        </div>
      </div>
      <div>
        <h4 style="color: var(--color-accent); font-family: var(--font-heading); font-size: 1.25rem; margin-bottom: 16px; margin-top: 0; letter-spacing: 0.05em; text-transform: uppercase;">PRODUK</h4>
        <div class="grid" style="gap:12px;">
          <a href="/collections/all">Katalog Produk</a>
          <a href="/pages/about-us">Tentang Montana</a>
          <a href="/blogs/news">Blog</a>
        </div>
      </div>
      <div>
        <h4 style="color: var(--color-accent); font-family: var(--font-heading); font-size: 1.25rem; margin-bottom: 16px; margin-top: 0; letter-spacing: 0.05em; text-transform: uppercase;">LAYANAN</h4>
        <div class="grid" style="gap:12px;">
          <a href="/pages/contact">Hubungi Kami</a>
          <a href="/pages/contact">Pesanan Grosir</a>
        </div>
      </div>
      <div>
        <h4 style="color: var(--color-accent); font-family: var(--font-heading); font-size: 1.25rem; margin-bottom: 16px; margin-top: 0; letter-spacing: 0.05em; text-transform: uppercase;">MARKETPLACE</h4>
        <div class="grid" style="gap:12px;">
          <a href="https://shopee.co.id/montanaid" target="_blank" rel="noopener">Shopee</a>
          <a href="https://www.tokopedia.com/montanaid" target="_blank" rel="noopener">Tokopedia</a>
          <a href="https://www.tiktok.com/@montanastationeryid" target="_blank" rel="noopener">TikTok Shop</a>
          <a href="https://www.lazada.co.id/shop/montana-id/" target="_blank" rel="noopener">Lazada</a>
        </div>
      </div>
    </div>
    <div class="footer__small" style="border-top: 1px solid var(--glass-border); padding-top: 24px; display: flex; justify-content: center; align-items: center; flex-wrap: wrap;">
      <span>&copy; {{ 'now' | date: '%Y' }} Montana. All rights reserved.</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Site footer",
  "settings": [
    {"type": "link_list", "id": "menu", "label": "Footer menu"},
    {"type": "text", "id": "footer_heading", "label": "Heading", "default": "Better tools for a smarter generation."},
    {"type": "textarea", "id": "footer_text", "label": "Text", "default": "Use this area for policy pages, support links, and trust-building information."}
  ]
}
{% endschema %}
