<footer class="footer">
  <div class="page-width footer__inner" style="display:block;">
    <div class="footer__grid" style="gap:48px;">
      <div>
        <a href="{{ routes.root_url }}" style="display:inline-block; margin-bottom: 20px;">
          <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" style="max-height: 48px; width: auto;" loading="lazy">
        </a>
        <h3 style="margin-top:0; color: var(--color-primary);">{{ section.settings.footer_heading }}</h3>
        <p style="color: rgba(255,255,255,0.7);">{{ section.settings.footer_text }}</p>
        <div style="margin-top: 24px; display: grid; gap: 8px; color: rgba(255,255,255,0.9);">
          <p style="margin:0;"><strong>Email:</strong> {{ settings.contact_email }}</p>
          <p style="margin:0;"><strong>Hours:</strong> {{ settings.business_hours }}</p>
        </div>
      </div>
      <div>
        <h4 style="color: var(--color-accent); font-family: var(--font-heading); font-size: 1.5rem; margin-bottom: 16px; margin-top: 0; letter-spacing: 0.05em;">QUICK LINKS</h4>
        <div class="grid" style="gap:12px;">
          <a href="/collections/all">Our Products</a>
          <a href="/pages/about-us">About Us</a>
          <a href="/pages/faq">FAQ</a>
          <a href="/policies/shipping-policy">Shipping Policy</a>
          <a href="/policies/refund-policy">Return Policy</a>
        </div>
      </div>
      <div>
        <h4 style="color: var(--color-accent); font-family: var(--font-heading); font-size: 1.5rem; margin-bottom: 16px; margin-top: 0; letter-spacing: 0.05em;">SUPPORT</h4>
        <div class="grid" style="gap:12px;">
          <a href="/pages/contact-us">Contact Us</a>
          <a href="https://wa.me/{{ settings.whatsapp_number }}" target="_blank" rel="noopener">WhatsApp Chat</a>
        </div>
      </div>
    </div>
    <div class="footer__small" style="border-top: 1px solid var(--glass-border); padding-top: 24px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
      <span>© {{ 'now' | date: '%Y' }} {{ shop.name }}. Built for Shopify OS 2.0.</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Site footer",
  "settings": [
    {"type": "link_list", "id": "menu", "label": "Footer menu"},
    {"type": "text", "id": "footer_heading", "label": "Heading", "default": "Better tools for a smarter generation."},
    {"type": "textarea", "id": "footer_text", "label": "Text", "default": "Use this area for policy pages, support links, and trust-building information."}
  ]
}
{% endschema %}
