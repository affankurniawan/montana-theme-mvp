<header class="header">
  <div class="page-width header__inner">
    <button class="mobile-menu-toggle" aria-label="Toggle menu" onclick="document.body.classList.toggle('menu-open')">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>

    <a href="{{ routes.root_url }}" class="header__logo">
      <img src="{{ 'logo.png' | asset_url }}" alt="Montana" style="max-height: 48px; width: auto;" loading="eager">
    </a>

    <nav class="nav" aria-label="Primary navigation">
      {%- assign current_path = request.path -%}
      {%- assign active_style = 'color: var(--color-accent); font-weight: 700; border-bottom: 2px solid var(--color-accent); padding-bottom: 4px;' -%}
      <a href="{{ routes.root_url }}" {% if current_path == routes.root_url %}style="{{ active_style }}"{% endif %}>Beranda</a>
      <a href="/pages/katalog" {% if current_path contains '/collections' or current_path contains '/products' or current_path contains '/pages/katalog' %}style="{{ active_style }}"{% endif %}>Katalog</a>
      <a href="/blogs/news" {% if current_path contains '/blogs' or current_path contains '/articles' %}style="{{ active_style }}"{% endif %}>Jurnal</a>
      <a href="/pages/about-us?view=about-us" {% if current_path == '/pages/about-us' %}style="{{ active_style }}"{% endif %}>Tentang Kami</a>
      <a href="/pages/contact-us?view=contact" {% if current_path == '/pages/contact-us' %}style="{{ active_style }}"{% endif %}>Hubungi Kami</a>
    </nav>

    <div class="header__actions" style="display:flex; gap:12px; align-items:center;">
      {%- if section.settings.show_search -%}
        <a href="{{ routes.search_url }}">Cari</a>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a href="/pages/katalog" class="button button--accent" style="display:inline-flex; align-items:center; gap:6px; font-size:0.8rem; padding:6px 20px; min-height:auto; font-weight:700;">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
          <span class="cta-label-text">{{ section.settings.cta_label }}</span>
        </a>
      {%- endif -%}
    </div>
  </div>

  <div class="mobile-drawer-overlay" onclick="document.body.classList.remove('menu-open')"></div>
  <div class="mobile-drawer">
    <div class="mobile-drawer__header">
      <button class="mobile-menu-close" aria-label="Close menu" onclick="document.body.classList.remove('menu-open')">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
    <nav class="mobile-nav">
      {%- assign mobile_active_style = 'color: var(--color-accent); font-weight: 700; border-bottom-color: var(--color-accent);' -%}
      <a href="{{ routes.root_url }}" {% if current_path == routes.root_url %}style="{{ mobile_active_style }}"{% endif %}>Beranda</a>
      <a href="/pages/katalog" {% if current_path contains '/collections' or current_path contains '/products' or current_path contains '/pages/katalog' %}style="{{ mobile_active_style }}"{% endif %}>Katalog</a>
      <a href="/blogs/news" {% if current_path contains '/blogs' or current_path contains '/articles' %}style="{{ mobile_active_style }}"{% endif %}>Jurnal</a>
      <a href="/pages/about-us?view=about-us" {% if current_path == '/pages/about-us' %}style="{{ mobile_active_style }}"{% endif %}>Tentang Kami</a>
      <a href="/pages/contact-us?view=contact" {% if current_path == '/pages/contact-us' %}style="{{ mobile_active_style }}"{% endif %}>Hubungi Kami</a>
    </nav>
  </div>

  <style>
    /* Sticky Header System */
    #shopify-section-site-header,
    .shopify-section-group-header-group {
      position: sticky !important;
      top: 0 !important;
      z-index: 999 !important;
    }
    .header {
      background: var(--color-background, #0a0a0a);
      border-bottom: 1px solid rgba(255,255,255,0.15);
      box-shadow: 0 4px 30px rgba(0,0,0,0.8);
    }
    
    .mobile-menu-toggle { display: none; background: transparent; border: none; color: #fff; cursor: pointer; padding: 4px; }
    .mobile-drawer-overlay {
      position: fixed; top: 0; left: 0; width: 100%; height: 100vh; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
      z-index: 99; opacity: 0; pointer-events: none; transition: opacity 0.3s ease;
    }
    .mobile-drawer {
      position: fixed; top: 0; left: -100%; width: 85%; max-width: 400px; height: 100vh; background: var(--color-surface);
      z-index: 100; transition: left 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); padding: 32px 24px; border-right: 1px solid var(--glass-border);
      box-shadow: 0 0 50px rgba(0,0,0,0.8); overflow-y: auto;
    }
    body.menu-open { overflow: hidden; }
    body.menu-open .mobile-drawer-overlay { opacity: 1; pointer-events: auto; }
    body.menu-open .mobile-drawer { left: 0; }
    .mobile-drawer__header { display: flex; justify-content: flex-end; margin-bottom: 40px; }
    .mobile-menu-close { background: transparent; border: none; color: #fff; cursor: pointer; padding: 4px; transition: color 0.2s; }
    .mobile-menu-close:hover { color: var(--color-accent); }
    .mobile-nav { display: flex; flex-direction: column; gap: 24px; }
    .mobile-nav a { font-size: 1.25rem; font-weight: 600; font-family: var(--font-body); text-decoration: none; color: #fff; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 16px; transition: color 0.2s; }
    
    @media (max-width: 749px) {
      .mobile-menu-toggle { display: block; }
      .header__logo { margin-right: auto; margin-left: 16px; }
      .header__actions a[href*="search"] { display: none; }
      .cta-label-text { display: none; }
      .header__actions .button { padding: 12px; }
    }
  </style>
</header>

{% schema %}
{
  "name": "Site header",
  "settings": [
    {"type": "link_list", "id": "menu", "label": "Menu"},
    {"type": "checkbox", "id": "show_search", "label": "Show search link", "default": true},
    {"type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop now"},
    {"type": "url", "id": "cta_link", "label": "CTA link"}
  ]
}
{% endschema %}
