<header class="header">
  <div class="page-width header__inner">
    <a href="{{ routes.root_url }}" class="header__logo">
      <img src="{{ 'logo.png' | asset_url }}" alt="Montana" style="max-height: 48px; width: auto;" loading="eager">
    </a>

    <nav class="nav" aria-label="Primary navigation">
      {%- assign current_path = request.path -%}
      {%- assign active_style = 'color: var(--color-accent); font-weight: 700; border-bottom: 2px solid var(--color-accent); padding-bottom: 4px;' -%}
      <a href="/" {% if current_path == '/' %}style="{{ active_style }}"{% endif %}>Home</a>
      <a href="/collections/all" {% if current_path contains '/collections' or current_path contains '/products' %}style="{{ active_style }}"{% endif %}>Product</a>
      <a href="/blogs/news" {% if current_path contains '/blogs' or current_path contains '/articles' %}style="{{ active_style }}"{% endif %}>Blog</a>
      <a href="/pages/about-us" {% if current_path == '/pages/about-us' %}style="{{ active_style }}"{% endif %}>About Us</a>
      <a href="/pages/contact" {% if current_path == '/pages/contact' %}style="{{ active_style }}"{% endif %}>Contact Us</a>
    </nav>

    <div style="display:flex; gap:12px; align-items:center;">
      {%- if section.settings.show_search -%}
        <a href="{{ routes.search_url }}">Search</a>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link | default: routes.all_products_collection_url }}" class="button button--accent">{{ section.settings.cta_label }}</a>
      {%- endif -%}
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Site header",
  "settings": [
    {"type": "link_list", "id": "menu", "label": "Menu"},
    {"type": "checkbox", "id": "show_search", "label": "Show search link", "default": true},
    {"type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop now"},
    {"type": "url", "id": "cta_link", "label": "CTA link"}
  ]
}
{% endschema %}
