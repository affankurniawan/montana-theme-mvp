<section class="section section--spacious">
  <div class="page-width">
    {%- render 'section-heading', eyebrow: section.settings.eyebrow, title: section.settings.heading, text: section.settings.text -%}
    <div class="grid grid--3">
      <div class="contact-card">
        <h3>Email</h3>
        <p>{{ settings.contact_email }}</p>
      </div>
      <div class="contact-card">
        <h3>Business hours</h3>
        <p>{{ settings.business_hours }}</p>
      </div>
      <div class="contact-card">
        <h3>WhatsApp</h3>
        <p><a href="https://wa.me/{{ settings.whatsapp_number }}" target="_blank" rel="noopener">Open chat</a></p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact cards",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Talk to us"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Questions, partnerships, or bulk inquiry"},
    {"type": "textarea", "id": "text", "label": "Text", "default": "Make Montana easy to reach for retail questions, partnerships, and bulk orders."}
  ],
  "presets": [{"name": "Contact cards"}]
}
{% endschema %}
