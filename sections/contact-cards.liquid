<section class="section section--spacious">
  <div class="page-width">
    {%- render 'section-heading', eyebrow: section.settings.eyebrow, title: section.settings.heading, text: section.settings.text, alignment: 'center' -%}
    <div class="grid grid--3">
      <div class="contact-card" style="text-align: center;">
        <h3 style="color: var(--color-accent); font-family: var(--font-heading); font-size: 1.5rem; letter-spacing: 0.05em; margin-bottom: 12px; margin-top: 0;">Email</h3>
        <p style="margin: 0; color: #ccc;">{{ settings.contact_email }}</p>
      </div>
      <div class="contact-card" style="text-align: center;">
        <h3 style="color: var(--color-accent); font-family: var(--font-heading); font-size: 1.5rem; letter-spacing: 0.05em; margin-bottom: 12px; margin-top: 0;">Business hours</h3>
        <p style="margin: 0; color: #ccc;">{{ settings.business_hours }}</p>
      </div>
      <div class="contact-card" style="text-align: center;">
        <h3 style="color: var(--color-accent); font-family: var(--font-heading); font-size: 1.5rem; letter-spacing: 0.05em; margin-bottom: 12px; margin-top: 0;">WhatsApp</h3>
        <p style="margin: 0;"><a href="https://wa.me/{{ settings.whatsapp_number }}" target="_blank" rel="noopener" style="color: #fff; text-decoration: none; font-weight: 700; border-bottom: 2px solid var(--color-accent); padding-bottom: 4px; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em; display: inline-block;">Open chat</a></p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact cards",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Talk to us"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Questions, partnerships, or bulk inquiry"},
    {"type": "textarea", "id": "text", "label": "Text", "default": "Make Montana easy to reach for retail questions, partnerships, and bulk orders."}
  ],
  "presets": [{"name": "Contact cards"}]
}
{% endschema %}
