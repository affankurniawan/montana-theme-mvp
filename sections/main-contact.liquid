<section class="section">
  <style>
    .contact-layout { display: grid; grid-template-columns: 1.3fr 1fr; gap: 48px; align-items: start; }
    @media (max-width: 989px) { .contact-layout { grid-template-columns: 1fr; gap: 32px; } }
  </style>
  <div class="page-width">
    
    <div style="position: relative; margin-bottom: 48px; padding-top: 24px;">
      <h1 style="margin: 0; font-family: var(--font-heading); font-size: clamp(4rem, 10vw, 8rem); font-weight: 800; font-style: italic; color: transparent; -webkit-text-stroke: 1px rgba(255, 216, 0, 0.15); text-transform: uppercase; line-height: 0.8; letter-spacing: 0.05em; position: absolute; top: -10px; left: -10px; z-index: 0; pointer-events: none;">KONTAK</h1>
      <h2 style="margin: 0; position: relative; z-index: 1; font-family: var(--font-heading); font-size: 3rem; font-weight: 900; color: #fff; text-transform: uppercase; letter-spacing: 0.05em;">HUBUNGI KAMI</h2>
      <div style="width: 80px; height: 4px; background: var(--color-accent); margin-top: 12px; margin-bottom: 24px; position: relative; z-index: 1;"></div>
      <p style="margin: 0; position: relative; z-index: 1; color: #aaa; font-size: 1rem; max-width: 600px; line-height: 1.6;">Kami siap membantu kebutuhan stationery Anda. Hubungi tim kami atau gunakan formulir di bawah untuk konsultasi produk dan layanan Montana.</p>
    </div>

    <div class="contact-layout">
      <!-- Left Column: Form -->
      <div class="card" style="padding: 32px; background: #111; border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; display: flex; flex-direction: column; gap: 24px;">
        <h3 style="margin: 0; font-family: var(--font-heading); color: #fff; font-size: 1.2rem; display: flex; align-items: center; gap: 8px; text-transform: uppercase; font-weight: 800;">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg> KIRIM PESAN
        </h3>
        
        {%- form 'contact', class: 'contact-form' -%}
          {%- if form.posted_successfully? -%}
            <div style="padding:16px; margin-bottom:24px; background: rgba(0, 255, 0, 0.1); color: #4ade80; border: 1px solid #4ade80; border-radius: 6px;">Pesan Anda telah berhasil dikirim. Tim kami akan merespons secepatnya.</div>
          {%- endif -%}
          {%- if form.errors -%}
            <div style="padding:16px; margin-bottom:24px; background: rgba(255, 0, 0, 0.1); color: #f87171; border: 1px solid #f87171; border-radius: 6px;">{{ form.errors | default_errors }}</div>
          {%- endif -%}
          
          <div style="display:grid; grid-template-columns: 1fr 1fr; gap:24px;">
            <div class="field">
              <label for="ContactFormName" style="font-size:11px; font-weight:700; color:#aaa; letter-spacing:1px; text-transform:uppercase; margin-bottom:8px; display:block;">Nama Lengkap</label>
              <input id="ContactFormName" name="contact[name]" type="text" placeholder="John Doe" value="{{ form.name }}" required style="width: 100%; background: #1a1a1a; border: 1px solid rgba(255,255,255,0.1); padding: 14px 16px; color: #fff; border-radius: 6px; font-size: 0.9rem; outline: none; transition: border-color 0.2s;" onfocus="this.style.borderColor='#555'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'">
            </div>
            <div class="field">
              <label for="ContactFormEmail" style="font-size:11px; font-weight:700; color:#aaa; letter-spacing:1px; text-transform:uppercase; margin-bottom:8px; display:block;">Alamat Email</label>
              <input id="ContactFormEmail" name="contact[email]" type="email" placeholder="email@example.com" value="{{ form.email }}" required style="width: 100%; background: #1a1a1a; border: 1px solid rgba(255,255,255,0.1); padding: 14px 16px; color: #fff; border-radius: 6px; font-size: 0.9rem; outline: none; transition: border-color 0.2s;" onfocus="this.style.borderColor='#555'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'">
            </div>
            <div class="field" style="grid-column: 1 / -1; position: relative;">
              <label for="ContactFormSubject" style="font-size:11px; font-weight:700; color:#aaa; letter-spacing:1px; text-transform:uppercase; margin-bottom:8px; display:block;">Subjek</label>
              <select id="ContactFormSubject" name="contact[subject]" style="appearance: none; width: 100%; background: #1a1a1a; border: 1px solid rgba(255,255,255,0.1); padding: 14px 40px 14px 16px; color: #fff; border-radius: 6px; font-size: 0.9rem; outline: none; cursor: pointer; transition: border-color 0.2s;" onfocus="this.style.borderColor='#555'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'">
                <option value="Pilih Subjek" disabled selected>Pilih Subjek</option>
                <option value="Kerjasama Grosir (B2B)">Kerjasama Grosir (B2B)</option>
                <option value="Dukungan Teknis">Dukungan Teknis</option>
                <option value="Keluhan Pengiriman">Keluhan Pengiriman</option>
                <option value="Lainnya">Lainnya</option>
              </select>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" style="position: absolute; right: 16px; top: 40px; pointer-events: none; color: #aaa;"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </div>
            <div class="field" style="grid-column: 1 / -1;">
              <label for="ContactFormBody" style="font-size:11px; font-weight:700; color:#aaa; letter-spacing:1px; text-transform:uppercase; margin-bottom:8px; display:block;">Pesan</label>
              <textarea id="ContactFormBody" name="contact[body]" placeholder="Bagaimana kami bisa membantu Anda?" required style="width: 100%; background: #1a1a1a; border: 1px solid rgba(255,255,255,0.1); padding: 16px; color: #fff; border-radius: 6px; font-size: 0.9rem; outline: none; min-height: 120px; resize: vertical; transition: border-color 0.2s;" onfocus="this.style.borderColor='#555'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'">{{ form.body }}</textarea>
            </div>
            <div style="grid-column: 1 / -1; margin-top: 8px;">
              <button type="submit" style="width:100%; display:flex; align-items:center; justify-content:center; gap:8px; font-size:15px; font-family: var(--font-body); font-weight:800; padding:16px; background: var(--color-accent); color:#000; border:none; border-radius:6px; cursor:pointer; text-transform: uppercase; letter-spacing: 1px; transition: background 0.2s;" onmouseover="this.style.background='#e6c200'" onmouseout="this.style.background='var(--color-accent)'">
                KIRIM PERMINTAAN
              </button>
            </div>
          </div>
        {%- endform -%}
      </div>

      <!-- Right Column -->
      <div style="display: flex; flex-direction: column; gap: 24px;">
        
        <div class="card" style="padding: 32px; background: #111; border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; display: flex; flex-direction: column; gap: 24px;">
          <h3 style="margin: 0; font-family: var(--font-heading); color: #fff; font-size: 1.1rem; display: flex; align-items: center; gap: 8px; text-transform: uppercase; font-weight: 800;">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#ffd800" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg> STUDIO & WORKSHOP
          </h3>
          <div>
            <h4 style="margin: 0 0 8px; color: #fff; font-size: 1rem; font-weight: 700; text-transform: uppercase;">MONTANA STATIONERY HQ</h4>
            <p style="margin: 0; color: #aaa; font-size: 0.9rem; line-height: 1.6;">Komplek Permata Kota Q12-Q15 170 JL. P. Tubagus Angke,<br>Kel. Pejagalan, Kec. Penjaringan, Jakarta Utara,<br>DKI JAKARTA 14450<br>Indonesia</p>
          </div>
          <div style="display: flex; flex-direction: column; gap: 16px; margin-top: 8px;">
            <div style="display: flex; flex-direction: column; gap: 12px; font-size: 0.95rem; color: #ccc;">
              <div style="display: flex; align-items: center; gap: 12px;">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#ffd800" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path></svg>
                <span>Marketing 1: <a href="tel:+6285220739261" style="color: #fff; text-decoration: none;">+6285220739261</a></span>
              </div>
              <div style="display: flex; align-items: center; gap: 12px;">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="transparent" stroke-width="2"></svg>
                <span>Marketing 2: <a href="tel:+6285947213959" style="color: #fff; text-decoration: none;">+6285947213959</a></span>
              </div>
            </div>
            <div style="display: flex; align-items: center; gap: 12px; font-size: 0.95rem; color: #ccc;">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#ffd800" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              [Waiting Update]
            </div>
          </div>
        </div>

        <div class="card" style="padding: 32px; background: #111; border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; display: flex; flex-direction: column; gap: 24px;">
          <h3 style="margin: 0; font-family: var(--font-heading); color: #fff; font-size: 1.1rem; display: flex; align-items: center; gap: 8px; text-transform: uppercase; font-weight: 800;">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#ffd800" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> WAKTU OPERASIONAL
          </h3>
          <div style="display: flex; flex-direction: column; gap: 16px;">
            <div style="display: flex; justify-content: space-between; font-size: 0.85rem; color: #aaa; text-transform: uppercase; letter-spacing: 1px;">
              <span>Senin - Jumat</span>
              <span style="font-weight: 800; color: #fff;">08:00 - 17:00</span>
            </div>
            <div style="width: 100%; height: 1px; background: rgba(255,255,255,0.05);"></div>
            <div style="display: flex; justify-content: space-between; font-size: 0.85rem; color: #aaa; text-transform: uppercase; letter-spacing: 1px;">
              <span>Sabtu</span>
              <span style="font-weight: 800; color: #fff;">09:00 - 14:00</span>
            </div>
            <div style="width: 100%; height: 1px; background: rgba(255,255,255,0.05);"></div>
            <div style="display: flex; justify-content: space-between; font-size: 0.85rem; color: #aaa; text-transform: uppercase; letter-spacing: 1px;">
              <span>Minggu</span>
              <span style="font-weight: 800; color: var(--color-accent);">Tutup</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main contact",
  "settings": []
}
{% endschema %}
