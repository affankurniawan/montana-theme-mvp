<section class="section" style="padding-top: 48px; padding-bottom: 48px; background: transparent;">
  <div class="page-width">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 40px;">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }} style="flex: 1 1 160px; display: flex; flex-direction: column; align-items: center; text-align: center;">
          
          <div style="color: var(--color-accent); margin-bottom: 16px; display: flex; justify-content: center; align-items: center; width: 48px; height: 48px;">
            {%- case block.settings.icon -%}
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M9 12l2 2 4-4"></path></svg>
              {%- when 'star' -%}
                <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
              {%- when 'lightning' -%}
                <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
              {%- when 'clock' -%}
                <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              {%- when 'ribbon' -%}
                <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            {%- endcase -%}
          </div>
          
          <h4 style="margin: 0 0 8px; color: #fff; font-size: 0.95rem; font-weight: 700; font-family: var(--font-body); letter-spacing: 0.02em;">
            {{ block.settings.title }}
          </h4>
          
          {%- if block.settings.text != blank -%}
            <p style="margin: 0; color: #888; font-size: 0.85rem; line-height: 1.6;">
              {{ block.settings.text }}
            </p>
          {%- endif -%}
          
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Value strip",
  "settings": [],
  "blocks": [
    {
      "type": "item",
      "name": "Value Prop",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            {"value": "shield", "label": "Shield Check"},
            {"value": "star", "label": "Star"},
            {"value": "lightning", "label": "Lightning"},
            {"value": "clock", "label": "Clock"},
            {"value": "ribbon", "label": "Ribbon Medal"}
          ],
          "default": "shield"
        },
        {"type": "text", "id": "title", "label": "Title", "default": "Kualitas Tahan Lama"},
        {"type": "textarea", "id": "text", "label": "Text", "default": "Produk yang dirancang untuk penggunaan jangka panjang."}
      ]
    }
  ],
  "presets": [{
    "name": "Value strip",
    "blocks": [
      {
        "type": "item",
        "settings": {
          "icon": "shield",
          "title": "Kualitas Tahan Lama",
          "text": "Produk yang dirancang untuk penggunaan jangka panjang dengan material premium."
        }
      },
      {
        "type": "item",
        "settings": {
          "icon": "star",
          "title": "Harga Terjangkau",
          "text": "Kualitas tinggi dengan harga yang ramah di kantong untuk semua kalangan."
        }
      },
      {
        "type": "item",
        "settings": {
          "icon": "lightning",
          "title": "Desain Praktis",
          "text": "Dirancang ergonomis untuk kemudahan dan kenyamanan penggunaan sehari-hari."
        }
      },
      {
        "type": "item",
        "settings": {
          "icon": "clock",
          "title": "Siap Setiap Hari",
          "text": "Stok selalu tersedia dan siap kirim ke seluruh Indonesia."
        }
      },
      {
        "type": "item",
        "settings": {
          "icon": "ribbon",
          "title": "Garansi Kepuasan",
          "text": "Jaminan kualitas dan layanan purna jual terbaik untuk pelanggan."
        }
      }
    ]
  }]
}
{% endschema %}
