<section class="section">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div style="text-align:center; margin-bottom: 24px;">
        <span style="font-size:0.85rem; color:#888; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; margin:0; display:block;">{{ section.settings.heading }}</span>
      </div>
    {%- endif -%}
    <div class="value-strip">
      {%- for block in section.blocks -%}
        <div class="value-strip__item" {{ block.shopify_attributes }}>{{ block.settings.title }}</div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Value strip",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "The Montana Standard"}
  ],
  "blocks": [
    {"type": "item", "name": "Item", "settings": [{"type": "text", "id": "title", "label": "Title", "default": "Durable"}]}
  ],
  "presets": [{
    "name": "Value strip",
    "blocks": [
      {"type": "item", "settings": {"title": "Durable"}},
      {"type": "item", "settings": {"title": "Affordable"}},
      {"type": "item", "settings": {"title": "Practical"}},
      {"type": "item", "settings": {"title": "Everyday-ready"}}
    ]
  }]
}
{% endschema %}
