<section class="section">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div style="text-align:center; margin-bottom: 24px;">
        <span style="font-size:0.85rem; color:#888; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; margin:0; display:block;">{{ section.settings.heading }}</span>
      </div>
    {%- endif -%}
    <style>
      .value-strip-icon {
        color: var(--color-accent);
        display: flex;
        align-items: center;
        transition: color 0.3s ease;
      }
      .value-strip__item:hover .value-strip-icon {
        color: var(--color-background, #0a0a0a);
      }
    </style>
    <div class="value-strip">
      {%- for block in section.blocks -%}
        {%- assign title_down = block.settings.title | downcase -%}
        <div class="value-strip__item" {{ block.shopify_attributes }} style="display:flex; align-items:center; justify-content:center; gap:12px;">
          <span class="value-strip-icon">
             {%- if title_down contains 'durable' -%}
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
             {%- elsif title_down contains 'affordable' -%}
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
             {%- elsif title_down contains 'practical' -%}
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg>
             {%- elsif title_down contains 'everyday' -%}
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
             {%- else -%}
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
             {%- endif -%}
          </span>
          <span>{{ block.settings.title }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Value strip",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "The Montana Standard"}
  ],
  "blocks": [
    {"type": "item", "name": "Item", "settings": [{"type": "text", "id": "title", "label": "Title", "default": "Durable"}]}
  ],
  "presets": [{
    "name": "Value strip",
    "blocks": [
      {"type": "item", "settings": {"title": "Durable"}},
      {"type": "item", "settings": {"title": "Affordable"}},
      {"type": "item", "settings": {"title": "Practical"}},
      {"type": "item", "settings": {"title": "Everyday-ready"}}
    ]
  }]
}
{% endschema %}
