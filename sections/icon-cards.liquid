<section class="section section--spacious surface">
  <div class="page-width">
    {%- render 'section-heading', eyebrow: section.settings.eyebrow, title: section.settings.heading, text: section.settings.text -%}
    <div class="grid grid--4">
      {%- for block in section.blocks -%}
        <div class="icon-card" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
          {%- if block.settings.link_label != blank -%}
            <a href="{{ block.settings.link }}"><strong>{{ block.settings.link_label }}</strong></a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Icon cards",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Browse faster"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Shop by need"},
    {"type": "textarea", "id": "text", "label": "Text", "default": "Make the shopping experience easy, clean, and useful."}
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {"type": "text", "id": "title", "label": "Title", "default": "School"},
        {"type": "textarea", "id": "text", "label": "Text", "default": "Reliable basics for students and daily study routines."},
        {"type": "text", "id": "link_label", "label": "Link label", "default": "Browse"},
        {"type": "url", "id": "link", "label": "Link"}
      ]
    }
  ],
  "presets": [{
    "name": "Icon cards",
    "blocks": [
      {"type": "card", "settings": {"title": "School", "text": "Reliable basics for students and daily study routines."}},
      {"type": "card", "settings": {"title": "Office", "text": "Dependable tools that keep workspaces neat and efficient."}},
      {"type": "card", "settings": {"title": "Home", "text": "Practical essentials for daily household use."}},
      {"type": "card", "settings": {"title": "Business", "text": "Consistent quality for repeat buying and bulk needs."}}
    ]
  }]
}
{% endschema %}
