<section class="section section--spacious surface">
  <div class="page-width">
    {%- render 'section-heading', eyebrow: section.settings.eyebrow, title: section.settings.heading, text: section.settings.text, alignment: 'center' -%}
    <div class="grid grid--4">
      {%- for block in section.blocks -%}
        <div class="icon-card" style="display: flex; flex-direction: column; height: 100%;" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title }}" style="width:100%; height:180px; object-fit:cover; border-radius:8px; margin-bottom:16px;" loading="lazy">
          {%- else -%}
            {%- assign downcase_title = block.settings.title | downcase -%}
            {%- assign fallback_img = 'notebook.png' -%}
            {%- if downcase_title contains 'school' -%}{%- assign fallback_img = 'cat-school.png' -%}
            {%- elsif downcase_title contains 'office' -%}{%- assign fallback_img = 'cat-office.png' -%}
            {%- elsif downcase_title contains 'home' -%}{%- assign fallback_img = 'cat-home.png' -%}
            {%- elsif downcase_title contains 'business' -%}{%- assign fallback_img = 'cat-business.png' -%}
            {%- elsif downcase_title contains 'smart value' -%}{%- assign fallback_img = 'why-montana.png' -%}
            {%- elsif downcase_title contains 'built to last' -%}{%- assign fallback_img = 'produk-terbaru.png' -%}
            {%- elsif downcase_title contains 'everyday' -%}{%- assign fallback_img = 'pen-set.png' -%}
            {%- elsif downcase_title contains 'purpose' -%}{%- assign fallback_img = 'office-category.png' -%}
            {%- endif -%}
            <img src="{{ fallback_img | asset_url }}" alt="{{ block.settings.title }}" style="width:100%; height:180px; object-fit:cover; border-radius:8px; margin-bottom:16px;" loading="lazy">
          {%- endif -%}
          <div style="text-align: center; display: flex; flex-direction: column; flex-grow: 1;">
            <h3 style="color: var(--color-accent); font-family: var(--font-heading); margin: 0 0 12px 0; font-size: 1.5rem; letter-spacing: 0.05em;">{{ block.settings.title }}</h3>
            <p style="color: #ccc; line-height: 1.6; font-size: 0.95rem; margin: 0 0 24px 0; flex-grow: 1;">{{ block.settings.text }}</p>
            {%- if block.settings.link_label != blank -%}
              <a href="{{ block.settings.link }}" style="color: #fff; text-decoration: none; font-weight: 700; border-bottom: 2px solid var(--color-accent); padding-bottom: 4px; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em; display: inline-block; margin: auto auto 0 auto;">{{ block.settings.link_label }}</a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Icon cards",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Browse faster"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Shop by need"},
    {"type": "textarea", "id": "text", "label": "Text", "default": "Make the shopping experience easy, clean, and useful."}
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {"type": "text", "id": "title", "label": "Title", "default": "School"},
        {"type": "textarea", "id": "text", "label": "Text", "default": "Reliable basics for students and daily study routines."},
        {"type": "text", "id": "link_label", "label": "Link label", "default": "Browse"},
        {"type": "url", "id": "link", "label": "Link"}
      ]
    }
  ],
  "presets": [{
    "name": "Icon cards",
    "blocks": [
      {"type": "card", "settings": {"title": "School", "text": "Reliable basics for students and daily study routines."}},
      {"type": "card", "settings": {"title": "Office", "text": "Dependable tools that keep workspaces neat and efficient."}},
      {"type": "card", "settings": {"title": "Home", "text": "Practical essentials for daily household use."}},
      {"type": "card", "settings": {"title": "Business", "text": "Consistent quality for repeat buying and bulk needs."}}
    ]
  }]
}
{% endschema %}
