<section class="section section--spacious surface" id="icon-cards-{{ section.id }}">
  <style>
    #icon-cards-{{ section.id }} .section-heading h2 { color: var(--color-accent) !important; }
    #icon-cards-{{ section.id }} .section-heading p { color: rgba(230, 197, 51, 0.8) !important; }
    #icon-cards-{{ section.id }} .icon-card { 
      background: rgba(0, 0, 0, 0.2); 
      border-color: rgba(230, 197, 51, 0.1); 
    }
  </style>
  <div class="page-width">
    {%- render 'section-heading', eyebrow: section.settings.eyebrow, title: section.settings.heading, text: section.settings.text, alignment: 'center' -%}
    <div class="grid grid--4">
      {%- for block in section.blocks -%}
        <div class="icon-card" style="display: flex; flex-direction: column; height: 100%;" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title }}" style="width:100%; height:140px; object-fit:cover; border-radius:8px; margin-bottom:16px;" loading="lazy">
          {%- else -%}
            {%- assign downcase_title = block.settings.title | downcase -%}
            {%- assign fallback_img = 'notebook.png' -%}
            {%- if downcase_title contains 'sekolah' or downcase_title contains 'school' -%}{%- assign fallback_img = 'cat-school.png' -%}
            {%- elsif downcase_title contains 'kantor' or downcase_title contains 'office' -%}{%- assign fallback_img = 'cat-office.png' -%}
            {%- elsif downcase_title contains 'rumah' or downcase_title contains 'home' -%}{%- assign fallback_img = 'cat-home.png' -%}
            {%- elsif downcase_title contains 'bisnis' or downcase_title contains 'business' -%}{%- assign fallback_img = 'cat-business.png' -%}
            {%- elsif downcase_title contains 'smart value' -%}{%- assign fallback_img = 'why-value.png' -%}
            {%- elsif downcase_title contains 'built to last' -%}{%- assign fallback_img = 'why-durable.png' -%}
            {%- elsif downcase_title contains 'everyday' -%}{%- assign fallback_img = 'why-progress.png' -%}
            {%- elsif downcase_title contains 'purpose' -%}{%- assign fallback_img = 'why-purpose.png' -%}
            {%- elsif downcase_title contains 'mission' -%}{%- assign fallback_img = 'about_mission.png' -%}
            {%- elsif downcase_title contains 'vision' -%}{%- assign fallback_img = 'about_vision.png' -%}
            {%- elsif downcase_title contains 'promise' -%}{%- assign fallback_img = 'about_promise.png' -%}
            {%- elsif downcase_title contains 'role' -%}{%- assign fallback_img = 'about_role.png' -%}
            {%- endif -%}
            <img src="{{ fallback_img | asset_url }}" alt="{{ block.settings.title }}" style="width:100%; height:140px; object-fit:cover; border-radius:8px; margin-bottom:16px;" loading="lazy">
          {%- endif -%}
          <div style="text-align: center; display: flex; flex-direction: column; flex-grow: 1;">
            <h3 style="color: var(--color-accent); font-family: var(--font-heading); margin: 0 0 8px 0; font-size: 1.25rem; font-weight: 800; letter-spacing: 0.05em;">{{ block.settings.title }}</h3>
            <p style="color: rgba(230, 197, 51, 0.8); line-height: 1.6; font-size: 0.85rem; margin: 0 0 20px 0; flex-grow: 1;">{{ block.settings.text }}</p>
            {%- if block.settings.link_label != blank -%}
              <a href="{{ block.settings.link }}" style="color: var(--color-accent); text-decoration: none; font-weight: 800; border-bottom: 2px solid var(--color-accent); padding-bottom: 4px; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em; display: inline-block; margin: auto auto 0 auto;">{{ block.settings.link_label }}</a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Icon cards",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Browse faster"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Shop by need"},
    {"type": "textarea", "id": "text", "label": "Text", "default": "Make the shopping experience easy, clean, and useful."}
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {"type": "text", "id": "title", "label": "Title", "default": "School"},
        {"type": "textarea", "id": "text", "label": "Text", "default": "Reliable basics for students and daily study routines."},
        {"type": "text", "id": "link_label", "label": "Link label", "default": "Browse"},
        {"type": "url", "id": "link", "label": "Link"}
      ]
    }
  ],
  "presets": [{
    "name": "Icon cards",
    "blocks": [
      {"type": "card", "settings": {"title": "School", "text": "Reliable basics for students and daily study routines."}},
      {"type": "card", "settings": {"title": "Office", "text": "Dependable tools that keep workspaces neat and efficient."}},
      {"type": "card", "settings": {"title": "Home", "text": "Practical essentials for daily household use."}},
      {"type": "card", "settings": {"title": "Business", "text": "Consistent quality for repeat buying and bulk needs."}}
    ]
  }]
}
{% endschema %}
