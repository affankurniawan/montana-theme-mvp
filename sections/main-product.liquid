<section class="main-product">
  <div class="breadcrumbs"><a href="/">Home</a> / <a href="/collections/all-products">Product</a> / {{ product.title }}</div>
  <div class="product-layout">
    <div class="product-gallery">
      <style>
        .product-gallery {
          align-self: flex-start;
        }
        .gallery-main {
          border-radius: 12px;
          overflow: hidden;
          background: #111;
          aspect-ratio: 1/1;
          display: flex;
          align-items: center;
          justify-content: center;
          margin-bottom: 12px;
        }
        .gallery-main img {
          width: 100%;
          height: 100%;
          object-fit: contain;
        }
        .gallery-thumbnails {
          display: flex;
          flex-wrap: wrap;
          gap: 12px;
        }
        .thumbnail-item {
          width: calc(20% - 9.6px);
          aspect-ratio: 1/1;
          border-radius: 8px;
          overflow: hidden;
          background: #111;
          cursor: pointer;
          border: 2px solid transparent;
          transition: border-color 0.2s;
        }
        .thumbnail-item:hover, .thumbnail-item.active {
          border-color: var(--color-accent);
        }
        .thumbnail-item img {
          width: 100%;
          height: 100%;
          object-fit: cover;
          display: block;
        }
        @media (max-width: 767px) {
          .thumbnail-item { width: calc(25% - 9px); }
        }
      </style>
      {%- if product.media.size > 0 -%}
        <div class="gallery-main">
          {{ product.featured_media | image_url: width: 1200 | image_tag: widths: '600,900,1200', loading: 'eager', alt: product.title, id: 'MainProductImage' }}
        </div>
        {%- if product.media.size > 1 -%}
          <div class="gallery-thumbnails">
            {%- for media in product.media -%}
              <div class="thumbnail-item {% if forloop.first %}active{% endif %}" onclick="document.getElementById('MainProductImage').src='{{ media | image_url: width: 1200 }}'; document.getElementById('MainProductImage').srcset=''; document.querySelectorAll('.thumbnail-item').forEach(el => el.classList.remove('active')); this.classList.add('active');">
                {{ media | image_url: width: 300 | image_tag: loading: 'lazy', alt: product.title }}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- else -%}
        <div class="placeholder-box" style="background:#f0f0f0; color:#171717; min-height:520px; border-radius: 12px;">Upload product media</div>
      {%- endif -%}
    </div>
    <div>
      <span class="eyebrow">Built to last</span>
      <h1 style="font-size: 1.5rem; line-height: 1.3; margin: 8px 0 16px; font-weight: 700;">{{ product.title }}</h1>
      <div class="price" style="font-size: 1.75rem; font-family: var(--font-heading); font-weight: 700; color: var(--color-accent); margin-bottom: 24px;">{{ product.price | money }}</div>
      
      <div class="product-description" style="font-size: 0.95rem; line-height: 1.6; color: rgba(255,255,255,0.85); margin-bottom: 32px;">
        <style>
          .product-description img, .product-description iframe {
            display: none !important;
          }
        </style>
        {%- if product.description != blank -%}
          {{ product.description }}
        {%- else -%}
          <p>Discover durability and reliable quality with Montana's everyday essentials.</p>
        {%- endif -%}
      </div>

      {%- if product.variants.size > 1 -%}
        <div class="product-form">
          <strong>Variants</strong>
          <div class="variant-list">
            {%- for variant in product.variants -%}
              <span class="variant-chip">{{ variant.title }}</span>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      {%- form 'product', product, class: 'product-form' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <div class="grid grid--2">
          <div class="proof-card"><h3>Durable</h3><p>Use this block for durability proof from real product data or metafields.</p></div>
          <div class="proof-card"><h3>Smart value</h3><p>Keep product copy benefit-led, direct, and not overhyped.</p></div>
        </div>
        <div style="display:flex; gap:12px; flex-wrap:wrap; align-items:center;">
          <input type="number" name="quantity" min="1" value="1" style="width:92px; padding:14px 12px; border-radius:999px; border:1px solid rgba(23,23,23,.16);">
          <button type="submit" class="button button--accent">Add to cart</button>
        </div>
      {%- endform -%}

      <style>
        .btn-market {
          padding: 12px 14px;
          font-size: 0.8rem;
          font-weight: 700;
          text-align: center;
          color: white;
          text-decoration: none;
          border-radius: 999px;
          flex: 1 1 calc(50% - 8px);
          transition: transform 0.2s ease, filter 0.2s ease;
          border: none;
        }
        .btn-market:hover {
          transform: translateY(-2px);
          filter: brightness(1.1);
        }
        .btn-shopee { background-color: #EE4D2D; }
        .btn-tokopedia { background-color: #00AA5B; }
        .btn-lazada { background-color: #0F136D; }
        .btn-tiktok { background-color: #000000; border: 1px solid rgba(255,255,255,0.2); }
      </style>
      <div style="margin-top: 32px; border-top: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1); padding: 24px 0;">
        <span style="font-size: 0.75rem; font-family: var(--font-heading); text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.6); display: block; margin-bottom: 16px; text-align: center;">Atau Checkout via Marketplace</span>
        <div style="display: flex; gap: 8px; justify-content: center; flex-wrap: wrap;">
          <a href="https://shopee.co.id/montanaid" target="_blank" rel="noopener" class="btn-market btn-shopee">Shopee</a>
          <a href="https://www.tokopedia.com/montanaid" target="_blank" rel="noopener" class="btn-market btn-tokopedia">Tokopedia</a>
          <a href="https://www.lazada.co.id/shop/montana-id/" target="_blank" rel="noopener" class="btn-market btn-lazada">Lazada</a>
          <a href="https://www.tiktok.com/@montanastationeryid" target="_blank" rel="noopener" class="btn-market btn-tiktok">TikTok</a>
        </div>
      </div>

      <div class="grid grid--2" style="margin-top:24px;">
        <div class="proof-card"><h3>WhatsApp support</h3><p><a href="https://wa.me/{{ settings.whatsapp_number }}" target="_blank" rel="noopener">Ask product questions</a></p></div>
        <div class="proof-card"><h3>Bulk inquiry</h3><p><a href="/pages/contact">Contact us for retail, partnership, or bulk order.</a></p></div>
      </div>
    </div>
  </div>

  <div class="sticky-cart">
    <div>
      <strong>{{ product.title }}</strong><br>
      <span class="price">{{ product.price | money }}</span>
    </div>
    <button class="button button--accent" type="button" onclick="document.querySelector('form[action*=\'/cart/add\'] button[type=submit]').click()">Add</button>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": []
}
{% endschema %}
