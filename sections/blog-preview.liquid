<section class="section section--spacious surface">
  <div class="page-width">
    {%- render 'section-heading', eyebrow: section.settings.eyebrow, title: section.settings.heading, text: section.settings.text -%}
    {%- assign blog = blogs[section.settings.blog] -%}
    <div class="grid grid--3">
      {%- if blog != blank and blog.articles_count > 0 -%}
        {%- for article in blog.articles limit: section.settings.posts_to_show -%}
          {%- render 'article-card', article: article -%}
        {%- endfor -%}
      {%- else -%}
        {%- render 'article-card', placeholder_title: "5 Tips Memilih Alat Tulis Kantor yang Awet dan Ergonomis", placeholder_tag: "TIPS & TRIK", placeholder_date: "17 Mar 2026", placeholder_read: "5 menit", placeholder_excerpt: "Meningkatkan produktivitas kerja dengan kenyamanan optimal, dari pemilihan pulpen hingga perlengkapan pendukung." -%}
        {%- render 'article-card', placeholder_title: "Perjalanan Panjang Mengembangkan Lem Batang Bebas Residu", placeholder_tag: "INOVASI", placeholder_date: "12 Mar 2026", placeholder_read: "7 menit", placeholder_excerpt: "Menilik di balik layar laboratorium Montana dalam menciptakan formula lem batang ramah lingkungan dan berdaya rekat tinggi." -%}
        {%- render 'article-card', placeholder_title: "Panduan Grosir Alat Tulis: Menghemat Anggaran Sekolah", placeholder_tag: "PANDUAN", placeholder_date: "05 Mar 2026", placeholder_read: "6 menit", placeholder_excerpt: "Cara cerdas institusi pendidikan mengelola pengadaan alat tulis tanpa mengorbankan kualitas bagi peserta didiknya." -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blog preview",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Useful content"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Article highlights"},
    {"type": "textarea", "id": "text", "label": "Text", "default": "Prepare the blog structure now, then add SEO-driven content after launch."},
    {"type": "blog", "id": "blog", "label": "Blog"},
    {"type": "range", "id": "posts_to_show", "min": 2, "max": 6, "step": 1, "label": "Posts to show", "default": 3}
  ],
  "presets": [{"name": "Blog preview"}]
}
{% endschema %}
