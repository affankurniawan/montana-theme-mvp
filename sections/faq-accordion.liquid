<section class="section section--spacious surface">
  <div class="page-width">
    {%- render 'section-heading', eyebrow: section.settings.eyebrow, title: section.settings.heading, text: section.settings.text -%}
    <div class="grid" style="gap:12px;">
      {%- for block in section.blocks -%}
        <details class="faq-item" {{ block.shopify_attributes }}>
          <summary>{{ block.settings.question }}</summary>
          <div class="faq-item__content">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ accordion",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FAQ"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Quick answers"},
    {"type": "textarea", "id": "text", "label": "Text", "default": "Add trust-building operational answers here."}
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {"type": "text", "id": "question", "label": "Question", "default": "Do you support bulk orders?"},
        {"type": "textarea", "id": "answer", "label": "Answer", "default": "Yes. Use Contact Us or WhatsApp for retail, partnership, or bulk inquiries."}
      ]
    }
  ],
  "presets": [{
    "name": "FAQ accordion",
    "blocks": [
      {"type": "faq"},
      {"type": "faq", "settings": {"question": "Can I ask via WhatsApp?", "answer": "Yes. Add your WhatsApp number in Theme Settings so customers can contact the brand quickly."}}
    ]
  }]
}
{% endschema %}
