<section class="section section--spacious surface" style="background: transparent;">
  <div class="page-width">
    
    <!-- Section Header (Minimalist) -->
    <div style="text-align: center; max-width: 700px; margin: 0 auto 48px auto;">
      {%- if section.settings.eyebrow != blank -%}
        <span style="font-size:0.85rem; color:#888; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:12px;">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 style="color: #fff; font-family: var(--font-heading); font-size: 2.5rem; font-weight: 800; letter-spacing: 0.02em; margin: 0 0 16px 0;">
        {{ section.settings.heading }}
      </h2>
      <p style="color: #aaa; font-size: 1rem; line-height: 1.6; margin: 0;">
        {{ section.settings.text }}
      </p>
    </div>

    <!-- Minimalist Bento Layout Grid -->
    <style>
      .bento-container {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }
      .bento-card {
        background: var(--glass-bg, #111);
        border: 1px solid var(--glass-border, #222);
        border-radius: var(--radius, 12px);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        position: relative;
        transition: transform 0.3s ease, border-color 0.3s ease;
      }
      .bento-card:hover {
        transform: translateY(-4px);
        border-color: rgba(255, 216, 0, 0.4);
      }
      .bento-card__img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        z-index: 1;
        opacity: 0.5;
        transition: opacity 0.3s ease;
      }
      .bento-card:hover .bento-card__img {
        opacity: 0.7;
      }
      .bento-card__content {
        position: relative;
        z-index: 2;
        padding: 32px;
        display: flex;
        flex-direction: column;
        height: 100%;
        justify-content: flex-end;
        background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.2) 100%);
      }
      
      /* Bento Sizing Rules */
      .bento-card:nth-child(1) { grid-column: span 2; min-height: 340px; }
      .bento-card:nth-child(2) { grid-column: span 1; min-height: 340px; }
      .bento-card:nth-child(3) { grid-column: span 1; min-height: 340px; }
      .bento-card:nth-child(4) { grid-column: span 2; min-height: 340px; }

      @media (max-width: 900px) {
        .bento-container { grid-template-columns: 1fr 1fr; }
        .bento-card:nth-child(1), .bento-card:nth-child(4) { grid-column: span 2; }
        .bento-card:nth-child(2), .bento-card:nth-child(3) { grid-column: span 1; }
      }
      @media (max-width: 600px) {
        .bento-container { grid-template-columns: 1fr; }
        .bento-card { grid-column: span 1 !important; min-height: 280px !important; padding: 24px;}
      }
    </style>

    <div class="bento-container">
      {%- for block in section.blocks -%}
        <div class="bento-card" {{ block.shopify_attributes }}>
          
          {%- assign downcase_title = block.settings.title | downcase -%}
          {%- assign fallback_img = 'notebook.png' -%}
          {%- if downcase_title contains 'nilai' or downcase_title contains 'value' -%}{%- assign fallback_img = 'why-value.png' -%}
          {%- elsif downcase_title contains 'tahan' or downcase_title contains 'durable' -%}{%- assign fallback_img = 'why-durable.png' -%}
          {%- elsif downcase_title contains 'maju' or downcase_title contains 'progress' -%}{%- assign fallback_img = 'why-progress.png' -%}
          {%- elsif downcase_title contains 'lebih' or downcase_title contains 'purpose' -%}{%- assign fallback_img = 'why-purpose.png' -%}
          {%- endif -%}

          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title }}" class="bento-card__img" loading="lazy">
          {%- else -%}
            <img src="{{ fallback_img | asset_url }}" alt="{{ block.settings.title }}" class="bento-card__img" loading="lazy">
          {%- endif -%}

          <div class="bento-card__content">
            <h3 style="color: var(--color-accent); font-family: var(--font-heading); margin: 0 0 8px 0; font-size: 1.5rem; font-weight: 800; letter-spacing: 0.02em;">
              {{ block.settings.title }}
            </h3>
            <p style="color: #eee; line-height: 1.5; font-size: 0.95rem; margin: 0 0 16px 0; max-width: 400px;">
              {{ block.settings.text }}
            </p>
            {%- if block.settings.link_label != blank and block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" style="color: #fff; text-decoration: none; font-weight: 700; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em; display: inline-flex; align-items: center; gap: 8px;">
                {{ block.settings.link_label }}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bento Grid",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Mengapa Montana"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Kualitas Nyata. Harga Pantas."},
    {"type": "textarea", "id": "text", "label": "Text", "default": "Kami yakin kualitas luar biasa tidak harus dibayar dengan harga mewah."}
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {"type": "text", "id": "title", "label": "Title"},
        {"type": "textarea", "id": "text", "label": "Text"},
        {"type": "text", "id": "link_label", "label": "Link label"},
        {"type": "url", "id": "link", "label": "Link"},
        {"type": "image_picker", "id": "image", "label": "Image"}
      ]
    }
  ],
  "presets": [{
    "name": "Bento Grid",
    "blocks": [
      {"type": "card", "settings": {"title": "Nilai Cerdas", "text": "Kualitas tangguh yang sepadan dengan harganya."}},
      {"type": "card", "settings": {"title": "Tahan Lama", "text": "Esensial andal untuk penggunaan intens setiap hari."}},
      {"type": "card", "settings": {"title": "Kemajuan Harian", "text": "Produk yang membantu Anda belajar, bekerja, dan selalu siap."}},
      {"type": "card", "settings": {"title": "Lebih Dari Produk", "text": "Merek dengan ambisi besar memajukan edukasi."}}
    ]
  }]
}
{% endschema %}
