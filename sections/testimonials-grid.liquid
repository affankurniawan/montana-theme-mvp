<section class="section section--spacious surface" style="background: transparent;">
  <div class="page-width">
    
    <!-- Minimalist Section Header -->
    <div style="text-align: center; margin-bottom: 48px;">
      {%- if section.settings.eyebrow != blank -%}
        <span style="font-size:0.85rem; color:var(--color-accent); font-weight:800; text-transform:uppercase; letter-spacing:0.15em; display:block; margin-bottom:12px;">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 style="color: #fff; font-family: var(--font-heading); font-size: 2.5rem; font-weight: 800; letter-spacing: 0.02em; margin: 0;">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid--3">
      {%- for block in section.blocks -%}
        <article class="testimonial-card" style="background: var(--glass-bg, #111); border: 1px solid var(--glass-border, #222); border-radius: var(--radius, 12px); padding: 32px; display: flex; flex-direction: column; height: 100%; text-align: left; transition: transform 0.3s ease, border-color 0.3s ease;" {{ block.shopify_attributes }} onmouseover="this.style.transform='translateY(-4px)'; this.style.borderColor='rgba(255,216,0,0.3)';" onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='var(--glass-border, #222)';">
          
          <!-- Rating Stars -->
          <div style="display: flex; gap: 4px; margin-bottom: 24px; color: var(--color-accent);">
            {%- for i in (1..5) -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            {%- endfor -%}
          </div>

          <!-- Quote Text -->
          <p style="font-style: italic; font-size: 0.95rem; line-height: 1.6; color: #ccc; margin: 0 0 32px 0; flex-grow: 1;">
            "{{ block.settings.quote }}"
          </p>
          
          <!-- Identity Footer -->
          <div style="display: flex; align-items: center; gap: 16px; margin-top: auto;">
            {%- assign initial = block.settings.name | slice: 0, 1 | capitalize -%}
            <div style="width: 48px; height: 48px; border-radius: 50%; background: #e50000; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.25rem;">
              {{ initial | default: 'M' }}
            </div>
            <div>
              <strong style="color: #fff; font-family: var(--font-body); font-weight: 700; font-size: 1rem; display: block;">{{ block.settings.name }}</strong>
              <div style="color: #888; margin-top: 2px; font-size: 0.85rem;">{{ block.settings.meta }}</div>
            </div>
          </div>

        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials grid",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Testimoni"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Kata Mereka"}
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Quote",
      "settings": [
        {"type": "textarea", "id": "quote", "label": "Quote", "default": "Akhirnya ada pena yang tintanya tidak tembus dan tahan satu semester."},
        {"type": "text", "id": "name", "label": "Name", "default": "Ayu T."},
        {"type": "text", "id": "meta", "label": "Meta", "default": "Mahasiswa"}
      ]
    }
  ],
  "presets": [{
    "name": "Testimonials grid",
    "blocks": [
      {"type": "quote", "settings": {"quote": "Akhirnya ada pena yang tintanya tidak tembus dan tahan satu semester. Sangat sepadan.", "name": "Ayu T.", "meta": "Mahasiswa"}},
      {"type": "quote", "settings": {"quote": "Kami melengkapi seluruh kantor dengan Montana. Terlihat premium tanpa bikin kantong jebol.", "name": "Budi P.", "meta": "Manajer Kantor"}},
      {"type": "quote", "settings": {"quote": "Sempurna untuk perlengkapan sekolah anak-anak. Cukup awet untuk dipakai setahun penuh.", "name": "Siti K.", "meta": "Ibu"}}
    ]
  }]
}
{% endschema %}
