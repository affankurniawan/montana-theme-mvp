<section class="section" style="background:var(--color-surface); padding-top: 64px; padding-bottom: 64px;">
  <div class="page-width">
    <!-- Flex Container -->
    <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 32px;">
      
      <!-- Left: Title & Subtitle -->
      <div style="flex: 1 1 400px;">
        <h2 style="margin: 0 0 8px; font-family: var(--font-heading); font-size: 1.75rem; color: #fff; font-weight: 800; letter-spacing: 0.02em;">
          {{ section.settings.heading }}
        </h2>
        <p style="margin: 0; font-size: 0.95rem; color: #aaa; line-height: 1.5;">
          {{ section.settings.text }}
        </p>
      </div>

      <!-- Right: Marketplace Pills -->
      <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
        {%- for block in section.blocks -%}
          {%- assign downcase_title = block.settings.title | downcase -%}
          {%- assign fallback_img = '' -%}
          {%- assign bg_color = 'rgba(255,255,255,0.1)' -%}
          {%- assign border = 'none' -%}
          
          {%- if downcase_title contains 'shopee' -%}
            {%- assign fallback_img = 'logo-shopee.png' -%}
            {%- assign bg_color = '#f53d2d' -%}
          {%- elsif downcase_title contains 'tokopedia' -%}
            {%- assign fallback_img = 'logo-tokopedia.png' -%}
            {%- assign bg_color = '#42b549' -%}
          {%- elsif downcase_title contains 'lazada' -%}
            {%- assign fallback_img = 'logo-lazada.png' -%}
            {%- assign bg_color = '#0f136d' -%}
          {%- elsif downcase_title contains 'tiktok' -%}
            {%- assign fallback_img = 'logo-tiktok.png' -%}
            {%- assign bg_color = '#111111' -%}
            {%- assign border = '1px solid rgba(255,255,255,0.2)' -%}
          {%- endif -%}

          <a href="{{ block.settings.link }}" target="_blank" rel="noopener" {{ block.shopify_attributes }}
             style="display: inline-flex; align-items: center; justify-content: flex-start; width: 180px; box-sizing: border-box; gap: 12px; background: {{ bg_color }}; border: {{ border }}; border-radius: 999px; padding: 12px 20px; color: #fff; text-decoration: none; font-size: 0.95rem; font-weight: 700; transition: transform 0.2s, filter 0.2s;"
             onmouseover="this.style.transform='translateY(-3px)'; this.style.filter='brightness(1.1)';" 
             onmouseout="this.style.transform='translateY(0)'; this.style.filter='brightness(1)';">
            
            <div style="display: flex; align-items: center; justify-content: center; width: 26px; height: 26px; background: #ffffff; border-radius: 4px; padding: 2px; flex-shrink: 0;">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 48 }}" alt="{{ block.settings.title }}" loading="lazy" style="width: 100%; height: 100%; object-fit: contain;">
              {%- elsif fallback_img != '' -%}
                <img src="{{ fallback_img | asset_url }}" alt="{{ block.settings.title }}" loading="lazy" style="width: 100%; height: 100%; object-fit: contain;">
              {%- endif -%}
            </div>
            
            {{ block.settings.title }}
          </a>
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Marketplaces",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "Belanja di Official Store Kami"},
    {"type": "textarea", "id": "text", "label": "Text", "default": "Tersedia di marketplace favorit Anda — produk resmi, harga terbaik."}
  ],
  "blocks": [
    {
      "type": "marketplace",
      "name": "Marketplace",
      "settings": [
        {"type": "text", "id": "title", "label": "Marketplace Name"},
        {"type": "url", "id": "link", "label": "Link"},
        {"type": "image_picker", "id": "image", "label": "Logo"}
      ]
    }
  ],
  "presets": [{
    "name": "Marketplaces",
    "blocks": [
      {"type": "marketplace", "settings": {"title": "Shopee", "link": "https://shopee.co.id/"}},
      {"type": "marketplace", "settings": {"title": "Tokopedia", "link": "https://www.tokopedia.com/"}},
      {"type": "marketplace", "settings": {"title": "TikTok Shop", "link": "https://www.tiktok.com/"}},
      {"type": "marketplace", "settings": {"title": "Lazada", "link": "https://www.lazada.co.id/"}}
    ]
  }]
}
{% endschema %}
