<section class="section section--spacious surface" style="background:var(--color-surface); padding-top: 64px; padding-bottom: 64px;">
  <div class="page-width">
    {%- render 'section-heading', eyebrow: section.settings.eyebrow, title: section.settings.heading, text: section.settings.text, alignment: 'center' -%}
    <style>
      .marketplace-icon-card {
        text-align:center; padding:24px; display:flex; flex-direction:column; align-items:center; justify-content:center; cursor:pointer; 
        border-radius: 16px; border: 1px solid transparent; transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
      }
      .marketplace-icon-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.5);
      }
      .marketplace-icon-card img {
        height:76px; width:auto; min-width:76px; padding:10px 16px; background:#fff; border-radius:12px; margin-bottom:16px; object-fit:contain;
        border: 2px solid transparent; transition: all 0.3s ease;
      }
      .marketplace-icon-card:hover img {
        border-color: var(--color-accent);
        transform: scale(1.08);
        box-shadow: 0 8px 16px rgba(0,0,0,0.4);
      }
      .marketplace-icon-card .mp-title {
        margin:0; font-size:1.25rem; font-weight:800; font-style:italic; font-family:var(--font-heading); text-transform:uppercase; letter-spacing: 0.1em; transition: color 0.3s ease;
      }
      .marketplace-icon-card:hover .mp-title {
        color: var(--color-accent);
      }
    </style>
    <div class="grid grid--4" style="gap:24px;">
      {%- for block in section.blocks -%}
        <div class="marketplace-icon-card" onclick="window.open('{{ block.settings.link }}', '_blank')" {{ block.shopify_attributes }}>
          {%- assign downcase_title = block.settings.title | downcase -%}
          {%- assign fallback_img = '' -%}
          {%- if downcase_title contains 'shopee' -%}{%- assign fallback_img = 'logo-shopee.png' -%}
          {%- elsif downcase_title contains 'tokopedia' -%}{%- assign fallback_img = 'logo-tokopedia.png' -%}
          {%- elsif downcase_title contains 'lazada' -%}{%- assign fallback_img = 'logo-lazada.png' -%}
          {%- elsif downcase_title contains 'tiktok' -%}{%- assign fallback_img = 'logo-tiktok.png' -%}
          {%- endif -%}
          
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 160 }}" alt="{{ block.settings.title }}" loading="lazy">
          {%- elsif fallback_img != '' -%}
            <img src="{{ fallback_img | asset_url }}" alt="{{ block.settings.title }}" loading="lazy">
          {%- endif -%}
          <div class="mp-title">{{ block.settings.title }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Marketplaces",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Official Stores"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Shop on your favorite marketplace"},
    {"type": "textarea", "id": "text", "label": "Text", "default": "We are available on all major platforms for your convenience and secure transactions."}
  ],
  "blocks": [
    {
      "type": "marketplace",
      "name": "Marketplace",
      "settings": [
        {"type": "text", "id": "title", "label": "Marketplace Name"},
        {"type": "url", "id": "link", "label": "Link"},
        {"type": "image_picker", "id": "image", "label": "Logo"}
      ]
    }
  ],
  "presets": [{
    "name": "Marketplaces",
    "blocks": [
      {"type": "marketplace", "settings": {"title": "Shopee", "link": "https://shopee.co.id/"}},
      {"type": "marketplace", "settings": {"title": "Tokopedia", "link": "https://www.tokopedia.com/"}},
      {"type": "marketplace", "settings": {"title": "Lazada", "link": "https://www.lazada.co.id/"}},
      {"type": "marketplace", "settings": {"title": "TikTok Shop", "link": "https://www.tiktok.com/"}}
    ]
  }]
}
{% endschema %}
