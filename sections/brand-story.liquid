<style>
  .brand-story-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }
  @media screen and (min-width: 860px) {
    .brand-story-grid {
      grid-template-columns: 1fr 1.1fr;
      gap: 8%;
    }
    .brand-story-grid.image-right .story-image {
      order: 2;
    }
    .brand-story-grid.image-right .story-text {
      order: 1;
    }
  }
  
  .story-image img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 16/10;
    border-radius: 12px;
    box-shadow: 0 24px 50px rgba(0,0,0,0.5);
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  
  .story-image:hover img {
    transform: scale(1.02);
  }

  .story-text-content p {
    margin-bottom: 1.5em;
  }
  .story-text-content p:last-child {
    margin-bottom: 0;
  }
  .story-text-content strong {
    color: #121315;
    font-weight: 800;
  }
</style>

<section class="section" style="padding: 100px 0; background: var(--color-background);">
  <div class="page-width">
    <!-- Grid Layout -->
    <div class="brand-story-grid {% if section.settings.layout == 'right' %}image-right{% endif %}">
      
      <!-- Image side -->
      <div class="story-image">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
        {%- else -%}
          {%- if section.settings.asset_image != blank -%}
            <img src="{{ section.settings.asset_image | asset_url }}" loading="lazy" alt="Brand Story">
          {%- else -%}
            <div style="width: 100%; aspect-ratio: 16/10; background: #222; border-radius: 12px;"></div>
          {%- endif -%}
        {%- endif -%}
      </div>

      <!-- Text side -->
      <div class="story-text">
        <div style="font-family: var(--font-heading); color: #121315; font-size: 0.85rem; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 16px; font-weight: 800;">
          {{ section.settings.eyebrow }}
        </div>
        <h2 style="font-family: var(--font-heading); font-size: clamp(2rem, 3.5vw, 3rem); color: #121315; margin: 0 0 32px; line-height: 1.15; letter-spacing: -0.01em;">
          {{ section.settings.heading }}
        </h2>
        <div class="story-text-content" style="color: rgba(18,19,21,0.8); font-size: 1.05rem; line-height: 1.75;">
          {{ section.settings.text }}
        </div>
      </div>
      
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
       "type": "image_picker",
       "id": "image",
       "label": "Image"
    },
    {
       "type": "text",
       "id": "asset_image",
       "label": "Asset Image Fallback (filename)"
    },
    {
       "type": "text",
       "id": "eyebrow",
       "label": "Eyebrow",
       "default": "ASAL USUL"
    },
    {
       "type": "text",
       "id": "heading",
       "label": "Heading",
       "default": "Cerita Kami"
    },
    {
       "type": "richtext",
       "id": "text",
       "label": "Text",
       "default": "<p>Montana dibangun dengan keyakinan sederhana: alat yang lebih baik menciptakan kebiasaan yang lebih baik, dan kebiasaan yang lebih baik membangun generasi yang lebih cerdas.</p><p>Di sekolah, di tempat kerja, di rumah, dan di usaha kecil, orang mengandalkan kebutuhan sehari-hari untuk menulis, mengatur, belajar, bersiap, dan terus bergerak.</p><p><strong>Montana hadir untuk menyelesaikan ini.</strong> Kami membuat kebutuhan dasar yang tahan lama, dapat diandalkan, dan terjangkau.</p>"
    },
    {
       "type": "select",
       "id": "layout",
       "label": "Image alignment",
       "options": [
         {"value": "left", "label": "Image on Left"},
         {"value": "right", "label": "Image on Right"}
       ],
       "default": "left"
    }
  ],
  "presets": [
    {
       "name": "Brand Story"
    }
  ]
}
{% endschema %}
