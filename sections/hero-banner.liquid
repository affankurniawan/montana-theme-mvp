<section class="hero-banner-video" style="position:relative; width:100%; min-height:85vh; display:flex; align-items:center; justify-content:center; overflow:hidden; background: var(--color-background);">
  <!-- SVG Animated Background Layer -->
  <div class="video-bg-layer" style="position:absolute; top:0; left:0; width:100%; height:120%; z-index:1; transform-origin:center top;">
    {%- if section.settings.video != null -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, style: 'width: 100%; height: 100%; object-fit: cover;' }}
    {%- else -%}
      <div class="floating-icons" style="position:absolute; width:100%; height:100%; top:0; left:0; overflow:hidden;">
        <svg class="bg-icon" style="position:absolute; width:120px; height:120px; fill:none; stroke:var(--color-accent); stroke-width:1.5; opacity:0.15; top:10%; left:15%;" viewBox="0 0 24 24"><path d="M3 3v18h18V3H3zm14 14H7v-2h10v2zm0-4H7v-2h10v2zm0-4H7V7h10v2z"/></svg>
        <svg class="bg-icon" style="position:absolute; width:80px; height:80px; fill:none; stroke:#fff; stroke-width:2; opacity:0.08; top:60%; left:25%;" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        <svg class="bg-icon" style="position:absolute; width:140px; height:140px; fill:none; stroke:var(--color-primary); stroke-width:1.5; opacity:0.25; top:15%; left:80%;" viewBox="0 0 24 24"><path d="M21 3l-6 6-4-4 6-6 4 4z M15 9l-9 9-4 1 1-4 9-9 4 4z"/></svg>
        <svg class="bg-icon" style="position:absolute; width:100px; height:100px; fill:none; stroke:var(--color-accent); stroke-width:1; opacity:0.15; top:70%; left:75%;" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
        <svg class="bg-icon" style="position:absolute; width:70px; height:70px; fill:none; stroke:#fff; stroke-width:2; opacity:0.1; top:35%; left:50%;" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <svg class="bg-icon" style="position:absolute; width:220px; height:220px; fill:none; stroke:var(--color-primary); stroke-width:1; opacity:0.05; top:85%; left:5%;" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
      </div>
    {%- endif -%}
  </div>

  <!-- Overlay -->
  <div style="position:absolute; top:0; left:0; width:100%; height:100%; background:linear-gradient(180deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.8) 100%); z-index:2;"></div>

  <!-- Content Layer -->
  <div class="page-width" style="position:relative; z-index:3; text-align:center; color:#fff; max-width:800px;">
    <div class="gsap-hero-content">
      <div class="gsap-hero-eyebrow" style="font-family:var(--font-heading); color:var(--color-accent); font-size:clamp(1.2rem, 2vw, 1.5rem); letter-spacing:0.1em; margin-bottom:12px; text-transform:uppercase;">{{ section.settings.eyebrow }}</div>
      <h1 class="gsap-hero-heading" style="font-family:var(--font-heading); font-size:clamp(3.5rem, 6vw, 7rem); margin:0 0 24px; line-height:1; letter-spacing:0.02em;">{{ section.settings.heading }}</h1>
      <p class="gsap-hero-text" style="font-size:clamp(1rem, 2vw, 1.25rem); color:rgba(255,255,255,0.85); margin:0 auto 32px; max-width: 600px; line-height:1.6;">{{ section.settings.text }}</p>
      
      <div class="gsap-hero-buttons" style="display:flex; justify-content:center; gap:16px; flex-wrap:wrap;">
        {%- if section.settings.primary_label != blank -%}
          <a href="/pages/katalog" class="button button--accent" style="font-size:1.1rem; padding: 14px 28px;">{{ section.settings.primary_label }}</a>
        {%- endif -%}
        {%- if section.settings.secondary_label != blank -%}
          <a href="{{ section.settings.secondary_link }}" class="button button--secondary" style="font-size:1.1rem; padding: 14px 28px; border-color:#fff; color:#fff;">{{ section.settings.secondary_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    gsap.registerPlugin(ScrollTrigger);

    // Floating SVG Icons Background Animation
    const icons = gsap.utils.toArray('.bg-icon');
    if (icons.length > 0) {
      icons.forEach((icon, i) => {
        gsap.to(icon, {
          y: "random(-150, -50)",
          x: "random(-50, 50)",
          rotation: "random(-45, 45)",
          duration: "random(12, 25)",
          repeat: -1,
          yoyo: true,
          ease: "sine.inOut"
        });
      });
    }

    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });
    tl.fromTo(".gsap-hero-eyebrow", { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 1 }, "+=0.2")
      .fromTo(".gsap-hero-heading", { opacity: 0, scale: 0.9 }, { opacity: 1, scale: 1, duration: 1.2, ease: "expo.out" }, "-=0.6")
      .fromTo(".gsap-hero-text", { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 1 }, "-=0.8")
      .fromTo(".gsap-hero-buttons", { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 1 }, "-=0.8");

    // ScrollTrigger Parallax for Video/SVG Background
    gsap.to(".video-bg-layer", {
      yPercent: 25,
      ease: "none",
      scrollTrigger: {
        trigger: ".hero-banner-video",
        start: "top top",
        end: "bottom top",
        scrub: true
      }
    });

    // ScrollTrigger Fade & Slide for Content Overlay
    gsap.to(".gsap-hero-content", {
      y: -100,
      opacity: 0,
      ease: "none",
      scrollTrigger: {
        trigger: ".hero-banner-video",
        start: "top top",
        end: "center top",
        scrub: true
      }
    });
  });
</script>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Smart value essentials"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Be Smart with Montana"},
    {"type": "textarea", "id": "text", "label": "Text", "default": "Durable, high-quality essentials at prices that make sense for school, work, home, and business."},
    {"type": "video", "id": "video", "label": "Background Video"},
    {"type": "text", "id": "primary_label", "label": "Primary button label", "default": "Shop products"},
    {"type": "url", "id": "primary_link", "label": "Primary button link"},
    {"type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "About Montana"},
    {"type": "url", "id": "secondary_link", "label": "Secondary button link"}
  ],
  "presets": [{"name": "Hero banner"}]
}
{% endschema %}
