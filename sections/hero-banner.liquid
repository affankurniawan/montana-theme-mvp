<section class="section section--spacious">
  <div class="page-width hero">
    <div>
      {%- render 'section-heading', eyebrow: section.settings.eyebrow, title: section.settings.heading, text: section.settings.text -%}
      <div style="display:flex; gap:12px; flex-wrap:wrap;">
        {%- if section.settings.primary_label != blank -%}
          <a href="{{ section.settings.primary_link }}" class="button button--accent">{{ section.settings.primary_label }}</a>
        {%- endif -%}
        {%- if section.settings.secondary_label != blank -%}
          <a href="{{ section.settings.secondary_link }}" class="button button--secondary">{{ section.settings.secondary_label }}</a>
        {%- endif -%}
      </div>
    </div>
    <div class="hero__media">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1200 | image_tag: widths: '600,900,1200', loading: 'eager', alt: section.settings.heading }}
      {%- else -%}
        <img src="{{ 'produk-terbaru.png' | asset_url }}" alt="Montana Hero Banner" style="width: 100%; height: 100%; object-fit: cover; border-radius: inherit;" loading="eager">
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Smart value essentials"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Be Smart with Montana"},
    {"type": "textarea", "id": "text", "label": "Text", "default": "Durable, high-quality essentials at prices that make sense for school, work, home, and business."},
    {"type": "image_picker", "id": "image", "label": "Image"},
    {"type": "text", "id": "primary_label", "label": "Primary button label", "default": "Shop products"},
    {"type": "url", "id": "primary_link", "label": "Primary button link"},
    {"type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "About Montana"},
    {"type": "url", "id": "secondary_link", "label": "Secondary button link"}
  ],
  "presets": [{"name": "Hero banner"}]
}
{% endschema %}
