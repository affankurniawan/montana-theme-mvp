<section class="section section--spacious surface" style="background: transparent;">
  <div class="page-width">
    
    <!-- Minimalist Section Header -->
    <div style="text-align: center; max-width: 800px; margin: 0 auto 64px auto;">
      {%- if section.settings.eyebrow != blank -%}
        <span style="font-size:0.85rem; color:var(--color-accent); font-weight:800; text-transform:uppercase; letter-spacing:0.15em; display:block; margin-bottom:12px;">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 style="color: #fff; font-family: var(--font-heading); font-size: 2.8rem; font-weight: 800; letter-spacing: 0.02em; margin: 0 0 20px 0; line-height: 1.1;">
        {{ section.settings.heading }}
      </h2>
      <p style="color: #aaa; font-size: 1.05rem; line-height: 1.6; margin: 0;">
        {{ section.settings.text }}
      </p>
    </div>

    <!-- Numbered Timeline Alternating Layout -->
    <style>
      .foundation-timeline {
        display: flex;
        flex-direction: column;
        gap: 24px;
        max-width: 900px;
        margin: 0 auto;
      }
      .foundation-card {
        background: var(--glass-bg, #111);
        border: 1px solid var(--glass-border, #222);
        border-radius: var(--radius, 12px);
        padding: 40px;
        display: flex;
        align-items: center;
        gap: 48px;
        transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), border-color 0.4s ease;
        position: relative;
        overflow: hidden;
      }
      .foundation-card:hover {
        transform: translateY(-4px) scale(1.01);
        border-color: rgba(255, 216, 0, 0.5);
      }
      .foundation-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 4px; height: 100%;
        background: transparent;
        transition: background 0.3s ease;
      }
      .foundation-card:hover::before {
        background: var(--color-accent);
      }
      .f-number {
        font-family: var(--font-heading);
        font-size: 5rem;
        font-weight: 900;
        color: rgba(255,255,255,0.03);
        line-height: 0.8;
        letter-spacing: -0.05em;
        transition: color 0.4s ease;
      }
      .foundation-card:hover .f-number {
        color: rgba(255, 216, 0, 0.15);
      }
      .f-content {
        flex: 1;
      }
      .f-title {
        color: #fff;
        font-family: var(--font-heading);
        font-size: 1.5rem;
        font-weight: 800;
        margin: 0 0 12px 0;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }
      .f-text {
        color: #ccc;
        font-size: 1rem;
        line-height: 1.6;
        margin: 0;
      }

      @media (max-width: 768px) {
        .foundation-card {
          flex-direction: column;
          align-items: flex-start;
          gap: 20px;
          padding: 32px 24px;
        }
        .f-number { font-size: 3.5rem; }
      }
    </style>

    <div class="foundation-timeline">
      {%- for block in section.blocks -%}
        <div class="foundation-card" {{ block.shopify_attributes }}>
          <div class="f-number">0{{ forloop.index }}</div>
          <div class="f-content">
            <h3 class="f-title">{{ block.settings.title }}</h3>
            <p class="f-text">{{ block.settings.text }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Foundation",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Pondasi Merek"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Memberdayakan Kemajuan Harian Anda"},
    {"type": "textarea", "id": "text", "label": "Text", "default": "Kami yakin kualitas premium bukanlah keistimewaan yang eksklusif."}
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Line Item",
      "settings": [
        {"type": "text", "id": "title", "label": "Title"},
        {"type": "textarea", "id": "text", "label": "Text"}
      ]
    }
  ],
  "presets": [{
    "name": "About Foundation"
  }]
}
{% endschema %}
