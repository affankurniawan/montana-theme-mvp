<section class="section section--spacious surface" style="background: transparent;">
  <div class="page-width">
    
    <!-- Split Typography Header Variant -->
    {%- if section.settings.heading != blank -%}
    <div class="f-split-header" style="max-width: 1200px; margin: 0 auto 48px auto; display: flex; align-items: flex-end; justify-content: space-between; gap: 48px;">
      <div style="flex: 1; max-width: 600px;">
        <h2 style="color: #fff; font-family: var(--font-heading); font-size: 2.6rem; font-weight: 800; letter-spacing: -0.01em; margin: 0; line-height: 1.1;">
          {{ section.settings.heading }}
        </h2>
      </div>
      <div style="flex: 1; max-width: 500px;">
        <p style="color: #aaa; font-size: 1.05rem; line-height: 1.6; margin: 0;">
          {{ section.settings.text }}
        </p>
      </div>
    </div>
    <style>
      @media (max-width: 768px) {
        .f-split-header {
          flex-direction: column;
          align-items: flex-start !important;
          gap: 16px !important;
        }
      }
    </style>
    {%- endif -%}

    <!-- Cinematic Image Bento Variant -->
    <style>
      .f-bento-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
        max-width: 1200px;
        margin: 0 auto;
      }
      .f-bento-card {
        position: relative;
        border-radius: var(--radius);
        overflow: hidden;
        aspect-ratio: 16 / 10;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 48px;
        border: 1px solid rgba(255, 255, 255, 0.05);
      }
      .f-bento-bg {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        object-fit: cover;
        z-index: 1;
        transition: transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
      }
      .f-bento-card:hover .f-bento-bg {
        transform: scale(1.05);
      }
      .f-bento-overlay {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.15) 55%, transparent 100%);
        z-index: 2;
        transition: background 0.4s ease;
      }
      .f-bento-card:hover .f-bento-overlay {
        background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.05) 55%, transparent 100%);
      }
      .f-bento-content {
        position: relative;
        z-index: 3;
      }
      .f-meta {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 12px;
      }
      .f-num {
        color: var(--color-accent);
        font-family: var(--font-heading);
        font-size: 1.4rem;
        font-weight: 800;
        background: rgba(0,0,0,0.5);
        padding: 4px 12px;
        border-radius: 4px;
      }
      .f-title {
        color: #fff;
        font-family: var(--font-heading);
        font-size: 2.2rem;
        font-weight: 800;
        margin: 0;
        letter-spacing: 0.02em;
        text-shadow: 0 4px 12px rgba(0,0,0,0.5);
      }
      .f-text {
        color: #ddd;
        font-size: 1.1rem;
        line-height: 1.7;
        margin: 0;
        text-shadow: 0 2px 8px rgba(0,0,0,0.5);
      }

      @media (max-width: 900px) {
        .f-bento-grid {
          grid-template-columns: 1fr;
        }
        .f-bento-card {
          aspect-ratio: auto;
          min-height: 400px;
          padding: 32px;
        }
      }
    </style>

    <div class="f-bento-grid">
      {%- for block in section.blocks -%}
        {%- assign downcase_title = block.settings.title | downcase -%}
        {%- assign fallback_img = 'notebook.png' -%}
        {%- if downcase_title contains 'misi' -%}{%- assign fallback_img = 'about_mission.png' -%}
        {%- elsif downcase_title contains 'visi' -%}{%- assign fallback_img = 'about_vision.png' -%}
        {%- elsif downcase_title contains 'janji' -%}{%- assign fallback_img = 'about_promise.png' -%}
        {%- elsif downcase_title contains 'peran' -%}{%- assign fallback_img = 'about_role.png' -%}
        {%- endif -%}

        <div class="f-bento-card" {{ block.shopify_attributes }}>
          <img src="{{ fallback_img | asset_url }}" alt="{{ block.settings.title }}" loading="lazy" class="f-bento-bg">
          <div class="f-bento-overlay"></div>
          
          <div class="f-bento-content">
            <div class="f-meta">
              <div class="f-num">0{{ forloop.index }}</div>
              <h3 class="f-title">{{ block.settings.title }}</h3>
            </div>
            <p class="f-text">{{ block.settings.text }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Foundation",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "Memberdayakan Kemajuan Harian Anda"},
    {"type": "textarea", "id": "text", "label": "Text", "default": "Kami yakin kualitas premium bukanlah keistimewaan eksklusif."}
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Line Item",
      "settings": [
        {"type": "text", "id": "title", "label": "Title"},
        {"type": "textarea", "id": "text", "label": "Text"}
      ]
    }
  ],
  "presets": [{
    "name": "About Foundation"
  }]
}
{% endschema %}
