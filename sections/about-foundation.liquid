<section class="section section--spacious surface" style="background: transparent;">
  <div class="page-width">
    
    <!-- Editorial Section Header -->
    <div style="max-width: 800px; margin: 0 0 80px 0;">
      {%- if section.settings.eyebrow != blank -%}
        <span style="font-size:0.85rem; color:var(--color-accent); font-weight:800; text-transform:uppercase; letter-spacing:0.15em; display:block; margin-bottom:12px;">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 style="color: #fff; font-family: var(--font-heading); font-size: 3.5rem; font-weight: 800; letter-spacing: -0.02em; margin: 0 0 24px 0; line-height: 1.1;">
        {{ section.settings.heading }}
      </h2>
      <p style="color: #aaa; font-size: 1.15rem; line-height: 1.6; margin: 0; max-width: 600px;">
        {{ section.settings.text }}
      </p>
    </div>

    <!-- 2x2 Premium Quadrant Grid -->
    <style>
      .foundation-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0; /* Handled by padding and inline borders */
        max-width: 1000px;
        margin: 0 auto;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
      }
      .f-card {
        padding: 48px 48px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        transition: background 0.4s ease;
      }
      .f-card:nth-child(odd) {
        border-right: 1px solid rgba(255, 255, 255, 0.08);
      }
      .f-card:hover {
        background: rgba(255, 255, 255, 0.02);
      }
      .f-number {
        font-family: var(--font-heading);
        font-size: 2.5rem;
        color: var(--color-accent);
        font-weight: 300;
        line-height: 1;
        margin-bottom: 16px;
        opacity: 0.8;
      }
      .f-title {
        color: #fff;
        font-family: var(--font-heading);
        font-size: 2rem;
        font-weight: 800;
        margin: 0 0 16px 0;
        letter-spacing: 0.01em;
      }
      .f-text {
        color: #aaa;
        font-size: 1.05rem;
        line-height: 1.7;
        font-weight: 400;
        margin: 0;
      }

      @media (max-width: 768px) {
        .foundation-grid {
          grid-template-columns: 1fr;
        }
        .f-card {
          padding: 32px 0;
        }
        .f-card:nth-child(odd) {
          border-right: none;
        }
      }
    </style>

    <div class="foundation-grid">
      {%- for block in section.blocks -%}
        <div class="f-card" {{ block.shopify_attributes }}>
          <div class="f-number">0{{ forloop.index }}.</div>
          <h3 class="f-title">{{ block.settings.title }}</h3>
          <p class="f-text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Foundation",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Memberdayakan Kemajuan Harian Anda"},
    {"type": "textarea", "id": "text", "label": "Text", "default": "Kami yakin kualitas premium bukanlah keistimewaan eksklusif."}
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Line Item",
      "settings": [
        {"type": "text", "id": "title", "label": "Title"},
        {"type": "textarea", "id": "text", "label": "Text"}
      ]
    }
  ],
  "presets": [{
    "name": "About Foundation"
  }]
}
{% endschema %}
