<article class="card product-card">
  <a href="{{ product.url }}" class="product-card__media">
    {%- if product.featured_image != blank -%}
      {{ product.featured_image | image_url: width: 640 | image_tag: widths: '320,480,640', loading: 'lazy', alt: product.title }}
    {%- else -%}
      <img src="{{ 'pen-set.png' | asset_url }}" alt="{{ product.title | default: 'Montana Product' }}" loading="lazy" style="width:100%; height:100%; object-fit:cover;">
    {%- endif -%}
  </a>
  <div class="product-card__content" style="text-align: center; padding: 16px;">
    {%- if product.tags contains 'promo' -%}<span class="badge" style="background-color: var(--color-accent); color: #000; font-weight: 700; padding: 4px 8px; border-radius: 4px; font-size: 0.75rem; text-transform: uppercase; display: inline-block; margin-bottom: 8px;">Promo</span>{%- endif -%}
    <h3 style="margin: 0 0 8px 0; font-family: var(--font-heading); font-size: 1.25rem; letter-spacing: 0.05em;"><a href="{{ product.url }}" style="color: #fff; text-decoration: none;">{{ product.title }}</a></h3>
    <div class="price" style="color: var(--color-accent); font-weight: 700; margin-bottom: 8px;">{{ product.price | money }}</div>
    <p style="color: #aaa; font-size: 0.9rem; margin: 0;">{{ product.description | strip_html | truncate: 90 }}</p>
  </div>
</article>
